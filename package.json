{
  "devDependencies": {
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.23",
    "tailwindcss": "^4.2.2",
    "wavesurfer.js": "^7.12.5"
  },
  "scripts": {
    "build": "run-p build:js build:css",
    "build:js": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --watch",
    "build:css": "rails tailwindcss:watch"
  }
}
