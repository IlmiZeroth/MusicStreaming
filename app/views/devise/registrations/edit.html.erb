<div class="mb-6 text-center sm:text-left">
  <h1 class="text-3xl font-black text-white sm:text-4xl">Редактирование аккаунта</h1>
  <p class="mt-2 text-neutral-400">Обновите данные входа.</p>
</div>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "grid gap-4" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.text_field :username, autocomplete: "username", placeholder: "Имя пользователя", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none placeholder:text-neutral-500 focus:border-green-400" %>
  <%= f.email_field :email, autocomplete: "email", placeholder: "Email", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none placeholder:text-neutral-500 focus:border-green-400" %>
  <%= f.password_field :password, autocomplete: "new-password", placeholder: "Новый пароль, необязательно", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none placeholder:text-neutral-500 focus:border-green-400" %>
  <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Повторите новый пароль", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none placeholder:text-neutral-500 focus:border-green-400" %>
  <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "Текущий пароль", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none placeholder:text-neutral-500 focus:border-green-400" %>
  <%= f.submit "Сохранить", class: "mt-2 rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300 cursor-pointer" %>
<% end %>

<div class="mt-6 rounded-2xl border border-red-400/40 bg-red-500/10 p-4">
  <div class="font-bold text-red-100">Удаление аккаунта</div>
  <%= button_to "Удалить аккаунт", registration_path(resource_name), data: { turbo_confirm: "Вы уверены?" }, method: :delete, class: "mt-3 rounded-2xl border border-red-400/60 px-4 py-2 text-red-100 transition hover:bg-red-500 cursor-pointer" %>
</div>
