<div class = "mr-20 mb-5">
      <h1 class = "text-4xl text-white font-bold">С возвращением</h1>
      <h2 class = "text-xl text-neutral-400 mt-1">Войдите в аккаунт</h2>
</div>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name),
               html: {class: ''}) do |f| %>
    <div class="field mt-4 text-neutral-600 bg-neutral-700 rounded-md h-10 w-80">
      <%= f.email_field :email, autofocus: true, placeholder: "Email", class: "h-full w-full text-neutral-400 px-3" %>
    </div>

    <div class="field mt-4 text-neutral-600 bg-neutral-700 rounded-md h-10 w-80">
      <%= f.password_field :password, placeholder: "Пароль", class: "h-full w-full text-neutral-400 px-3" %>
    </div>

    <%= f.submit "Войти", class: "mt-8 w-80 h-10 text-white rounded-xl bg-green-500
        hover:bg-green-400 transition-colors duration-300" %>
  <% end %>
  <%= render "devise/shared/links" %>