<div class="mb-6 text-center sm:text-left">
  <h1 class="text-3xl font-black text-white sm:text-4xl">Новый пароль</h1>
  <p class="mt-2 text-neutral-400">Введите новый пароль для аккаунта.</p>
</div>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "grid gap-4" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>
  <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "Новый пароль", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none placeholder:text-neutral-500 focus:border-green-400" %>
  <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Повторите новый пароль", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none placeholder:text-neutral-500 focus:border-green-400" %>
  <%= f.submit "Сменить пароль", class: "mt-2 rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300 cursor-pointer" %>
<% end %>

<%= render "devise/shared/links" %>
