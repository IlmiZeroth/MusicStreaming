 <div class = "mr-10 mb-5">
    <h1 class = "text-4xl text-white font-bold">Забыли пароль?</h1>
    <h2 class = "text-xl text-neutral-400 mt-1">Отправьте письмо для восстановления</h2>
  </div>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field mt-4 text-neutral-600 bg-neutral-700 rounded-md h-10 w-80">
    <%= f.email_field :email, autofocus: true, placeholder: "Email", class: "h-full w-full text-neutral-400 px-3"%>
  </div>

   <%= f.submit "Отправить письмо", class: "mt-5 w-80 h-10 text-white rounded-xl bg-green-500
        hover:bg-green-400 transition-colors duration-300" %>
<% end %>
<%= render "devise/shared/links" %>
