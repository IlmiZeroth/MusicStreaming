<div class="mb-6 text-center sm:text-left">
  <%= link_to root_path, class: "mb-6 inline-flex items-center gap-3" do %>
    <span class="flex h-10 w-10 overflow-hidden rounded-2xl bg-neutral-950 ring-1 ring-neutral-800"><%= image_tag "site-icon.png", class: "h-full w-full object-cover", alt: "MusicStreaming" %></span>
    <span class="font-black text-white">MusicStreaming</span>
  <% end %>
  <h1 class="text-3xl font-black text-white sm:text-4xl">Забыли пароль?</h1>
  <p class="mt-2 text-neutral-400">Отправим письмо для восстановления.</p>
</div>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "grid gap-4" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.email_field :email, autofocus: true, placeholder: "Email", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none placeholder:text-neutral-500 focus:border-green-400" %>
  <%= f.submit "Отправить письмо", class: "mt-2 rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300 cursor-pointer" %>
<% end %>

<%= render "devise/shared/links" %>
