<div class="mt-6 flex flex-col gap-2 text-center text-sm text-neutral-400">
  <% if controller_name != 'sessions' %>
    <%= link_to "Уже есть аккаунт? Войти", new_session_path(resource_name), class: "hover:text-white" %>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Создать аккаунт", new_registration_path(resource_name), class: "hover:text-white" %>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Забыли пароль?", new_password_path(resource_name), class: "hover:text-white" %>
  <% end %>
</div>
