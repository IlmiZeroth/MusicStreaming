<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <div class = "flex flex-row gap-2 text-neutral-400 mt-4">
    Нет аккаунта?
    <%= link_to "Создать", new_registration_path(resource_name), class: "text-green-500 hover:text-green-400" %>
  </div>
<% end %>
<%- if controller_name != 'sessions' %>
  <div class = "flex flex-row gap-2 text-neutral-400 mt-2">
    Уже есть аккаунт?
    <%= link_to "Войти", new_session_path(resource_name), class: "text-green-500 hover:text-green-400" %>
  </div>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <div class = "flex flex-row gap-2 text-neutral-400 ">
    Забыли пароль?
    <%= link_to "Восстановить", new_password_path(resource_name), class: "text-yellow-200 hover:text-yellow-300" %>
  </div>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name) %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name) %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p><%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false } %></p>
  <% end %>
<% end %>
