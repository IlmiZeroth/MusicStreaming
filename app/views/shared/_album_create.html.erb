<section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 sm:p-6" data-studio-target="albumForm">
  <h2 class="text-xl font-bold text-white">Создать альбом</h2>
  <%= form_with model: Album.new, local: true, html: { multipart: true, class: "mt-4 grid gap-4 lg:grid-cols-[auto_1fr_1fr_auto] lg:items-end" } do |f| %>
    <div data-controller="preview" data-preview-default-url-value="<%= asset_path('default-music.svg') %>" class="flex flex-col items-center gap-2">
      <div class="h-28 w-28 overflow-hidden rounded-2xl bg-neutral-800 ring-1 ring-neutral-700">
        <img data-preview-target="preview" class="h-full w-full object-cover" src="<%= asset_path('default-music.svg') %>" alt="Обложка" />
      </div>
      <%= f.label :cover_image, "Обложка", class: "cursor-pointer text-sm text-neutral-400 hover:text-white" %>
      <%= f.file_field :cover_image, class: "hidden", accept: "image/png,image/jpeg,image/jpg,image/webp", data: { action: "change->preview#preview", preview_target: "input" } %>
    </div>

    <div><%= f.label :name, "Название альбома *", class: "mb-2 block text-sm text-neutral-400" %><%= f.text_field :name, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400", required: true %></div>
    <div><%= f.label :release_date, "Дата выпуска *", class: "mb-2 block text-sm text-neutral-400" %><%= f.date_field :release_date, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400", required: true %></div>
    <%= f.submit "+ Создать", class: "rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300 cursor-pointer" %>
  <% end %>
</section>
