<% liked = current_user.liked_album?(album) %>
<% button_class = local_assigns.fetch(:button_class, 'hover:cursor-pointer rounded-2xl bg-neutral-900 p-1 shadow-xl/50 hover:bg-neutral-600 transition-colors') %>
<% icon_class = local_assigns.fetch(:icon_class, 'w-7 h-7') %>
<% liked_title = 'Убрать из любимых альбомов' %>
<% unliked_title = 'Добавить в любимые альбомы' %>

<%= button_tag type: 'button',
               class: button_class,
               title: liked ? liked_title : unliked_title,
               data: {
                 controller: 'like-button',
                 action: 'click->like-button#toggle',
                 like_button_resource_type_value: 'album',
                 like_button_resource_id_value: album.id,
                 like_button_like_url_value: like_album_path(album),
                 like_button_unlike_url_value: unlike_album_path(album),
                 like_button_liked_value: liked,
                 like_button_liked_icon_value: asset_path('unfollow.svg'),
                 like_button_unliked_icon_value: asset_path('follow.svg'),
                 like_button_liked_title_value: liked_title,
                 like_button_unliked_title_value: unliked_title
               } do %>
  <%= image_tag(liked ? 'unfollow.svg' : 'follow.svg', class: icon_class, data: { like_button_target: 'icon' }) %>
<% end %>
