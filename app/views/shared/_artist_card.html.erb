<div data-controller="artist-card"
     class="group relative w-40 shrink-0 rounded-[1.5rem] border border-neutral-800 bg-neutral-900/75 p-3 text-white shadow-lg shadow-black/10 transition duration-200 hover:border-neutral-700 hover:bg-neutral-900 sm:w-48 sm:p-4">
  <div class="relative aspect-square overflow-hidden rounded-[1.25rem] bg-neutral-800 ring-1 ring-neutral-800">
    <%= link_to profile_path(artist), class: "block h-full w-full" do %>
      <% if artist.avatar&.attached? %>
        <%= image_tag artist.avatar, class: "h-full w-full object-cover transition duration-300 group-hover:scale-105", alt: artist.name %>
      <% else %>
        <div class="flex h-full w-full items-center justify-center p-8">
          <%= image_tag 'default-user.svg', class: "h-full w-full", alt: artist.name %>
        </div>
      <% end %>
    <% end %>

    <% if local_assigns[:show_actions] %>
      <% following = current_user.following?(artist) %>
      <%= button_tag type: "button",
                     class: "absolute right-3 top-3 z-20 flex h-10 w-10 items-center justify-center rounded-full bg-neutral-950/85 shadow-lg transition hover:bg-neutral-800 hover:cursor-pointer",
                     title: following ? "Убрать артиста из коллекции" : "Добавить артиста в коллекцию",
                     data: {
                       controller: "follow-button",
                       action: "click->follow-button#toggle",
                       follow_button_follow_url_value: follow_path(artist),
                       follow_button_unfollow_url_value: unfollow_path(artist, from: 'collection'),
                       follow_button_followed_id_value: artist.id,
                       follow_button_following_value: following,
                       follow_button_followed_icon_value: asset_path('unfollow.svg'),
                       follow_button_unfollowed_icon_value: asset_path('follow.svg'),
                       follow_button_follow_title_value: "Добавить артиста в коллекцию",
                       follow_button_unfollow_title_value: "Убрать артиста из коллекции",
                       follow_button_remove_on_unfollow_value: true,
                       turbo: false
                     } do %>
        <%= image_tag(following ? 'unfollow.svg' : 'follow.svg', class: 'h-6 w-6', data: { follow_button_target: 'icon' }) %>
      <% end %>
    <% end %>
  </div>

  <div class="mt-3 min-w-0">
    <div class="truncate font-semibold text-white" title="<%= artist.name %>">
      <%= link_to artist.name, profile_path(artist), class: "hover:text-green-300" %>
    </div>
    <div class="mt-1 truncate text-sm text-neutral-500"><%= artist.tracks_count %> треков</div>
  </div>
</div>
