<% track_audio_url = track.audio_file.attached? ? audio_track_path(track) : '' %>
<% track_metadata_url = track.audio_file.attached? ? metadata_track_path(track) : '' %>
<% track_image_url = track.album.cover_image.attached? ? url_for(track.album.cover_image) : asset_path('default-music.svg') %>
<% liked = current_user.liked_track?(track) %>

<div data-controller="track-card"
     data-track-card-target="active"
     data-track-card-id-value="<%= track.id %>"
     data-track-card-artist-value="<%= track.user.username %>"
     data-track-card-name-value="<%= track.name %>"
     data-track-card-url-value="<%= track_audio_url %>"
     data-track-card-metadata-url-value="<%= track_metadata_url %>"
     data-track-card-duration-value="<%= track.duration %>"
     data-track-card-image-value="<%= track_image_url %>"
     data-track-card-liked-value="<%= liked %>"
     data-track-card-like-url-value="<%= like_track_path(track) %>"
     data-track-card-unlike-url-value="<%= unlike_track_path(track) %>"
     data-track-card-play-icon-value="<%= asset_path('play.svg') %>"
     data-track-card-pause-icon-value="<%= asset_path('pause.svg') %>"
     class="track-card text-white bg-neutral-800 h-13 ml-10 mr-10 my-0.5 pl-2 pr-5 rounded-2xl flex items-center flex-row flex-shrink-0 transition-all duration-200">
  <button type="button" data-action="click->track-card#playTrack" data-track-card-target="artwork" class="h-9 w-9 flex items-center justify-center hover:cursor-pointer rounded-full hover:bg-neutral-700 transition-all duration-200" title="Воспроизвести" aria-label="Воспроизвести">
    <%= image_tag "play.svg", class: "w-7 h-7", data: { track_card_target: "playIcon" } %>
  </button>
  <div class="track-info flex flex-col truncate w-full ml-2 mr-2">
    <div class="track-name text-white truncate" title="<%= track.name %>"><%= track.name %></div>
    <div class="track-artist text-neutral-400 hover:text-gray-400 truncate" title="<%= track.user.username %>"><%= link_to track.user.username, profile_path(track.user.id) %></div>
  </div>

  <% if local_assigns.fetch(:show_like, true) %>
    <div class="like-button w-8 h-8 mr-2 flex items-center justify-center">
      <%= render 'shared/track_like_button', track: track %>
    </div>
  <% end %>

  <% if local_assigns[:show_actions] || @show_actions %>
    <div class="delete-button w-7 h-7 mr-2">
      <%= button_to track_path(track),
                    method: :delete,
                    class: "hover:cursor-pointer",
                    data: { turbo_confirm: "Вы уверены, что хотите удалить трек '#{track.name}'?" } do %>
        <%= image_tag "delete.svg" %>
      <% end %>
    </div>
  <% end %>
</div>
