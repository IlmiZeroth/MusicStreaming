<% album_tracks = album.tracks.order(number_in_album: :asc) %>
<% album_queue = player_tracks_payload(album_tracks) %>
<% first_track = album_tracks.first %>
<% first_track_audio_url = first_track&.audio_file&.attached? ? audio_track_path(first_track) : '' %>
<% first_track_metadata_url = first_track&.audio_file&.attached? ? metadata_track_path(first_track) : '' %>
<% album_image_url = album.cover_image.attached? ? url_for(album.cover_image) : asset_path('default-music.svg') %>
<% first_track_liked = first_track.present? ? current_user.liked_track?(first_track) : false %>

<div data-controller="album-card"
     data-album-card-id-value="<%= first_track&.id %>"
     data-album-card-artist-value="<%= album.artist.name %>"
     data-album-card-name-value="<%= first_track&.name || album.name %>"
     data-album-card-url-value="<%= first_track_audio_url %>"
     data-album-card-metadata-url-value="<%= first_track_metadata_url %>"
     data-album-card-duration-value="<%= first_track&.duration %>"
     data-album-card-image-value="<%= album_image_url %>"
     data-album-card-liked-value="<%= first_track_liked %>"
     data-album-card-like-url-value="<%= like_track_path(first_track) if first_track.present? %>"
     data-album-card-unlike-url-value="<%= unlike_track_path(first_track) if first_track.present? %>"
     data-album-card-queue-name-value="Альбом: <%= album.name %>"
     data-album-card-queue-value="<%= album_queue.to_json %>"
     data-album-card-context-type-value="album"
     data-album-card-context-id-value="<%= album.id %>"
     data-album-card-context-url-value="<%= album_path(album) %>"
     data-album-card-play-icon-value="<%= asset_path('play.svg') %>"
     data-album-card-pause-icon-value="<%= asset_path('pause.svg') %>"
     class="group relative w-40 shrink-0 rounded-[1.5rem] border border-neutral-800 bg-neutral-900/75 p-3 text-white shadow-lg shadow-black/10 transition duration-200 hover:border-neutral-700 hover:bg-neutral-900 sm:w-48 sm:p-4">
  <% if local_assigns[:show_actions] %>
    <div class="absolute right-5 top-5 z-20">
      <%= button_to album_path(album),
                    method: :delete,
                    class: "flex h-9 w-9 items-center justify-center rounded-full bg-neutral-950/85 transition hover:bg-red-500/20 hover:cursor-pointer",
                    data: { turbo_confirm: "Вы уверены, что хотите удалить альбом '#{album.name}'?" } do %>
        <%= image_tag "delete.svg", class: "h-5 w-5" %>
      <% end %>
    </div>
  <% end %>

  <div class="relative aspect-square overflow-hidden rounded-[1.25rem] bg-neutral-800 ring-1 ring-neutral-800" data-album-card-target="artwork">
    <%= link_to album_path(album), class: "block h-full w-full", title: album.name do %>
      <% if album.cover_image&.attached? %>
        <%= image_tag album.cover_image, class: "h-full w-full object-cover transition duration-300 group-hover:scale-105", alt: album.name %>
      <% else %>
        <div class="flex h-full w-full items-center justify-center p-8">
          <%= image_tag 'default-music.svg', class: "h-full w-full", alt: album.name %>
        </div>
      <% end %>
    <% end %>

    <div class="absolute inset-0 flex items-end justify-between bg-gradient-to-t from-black/70 via-black/10 to-transparent p-3 opacity-100 transition sm:opacity-0 sm:group-hover:opacity-100 pointer-events-none">
      <button type="button"
              data-action="click->album-card#playTrack"
              class="pointer-events-auto flex h-10 w-10 items-center justify-center rounded-full bg-green-400 text-black shadow-lg shadow-black/30 transition hover:bg-green-300 disabled:opacity-40 disabled:cursor-default"
              title="Воспроизвести альбом"
              <%= 'disabled' unless first_track.present? && first_track_audio_url.present? %>>
        <%= image_tag "play.svg", class: "h-7 w-7", data: { album_card_target: "playIcon" } %>
      </button>

      <% if local_assigns.fetch(:show_like, true) %>
        <%= render 'shared/album_like_button',
                   album: album,
                   button_class: 'pointer-events-auto flex h-10 w-10 items-center justify-center rounded-full bg-neutral-950/85 shadow-lg shadow-black/30 transition hover:bg-neutral-800',
                   icon_class: 'h-6 w-6' %>
      <% end %>
    </div>
  </div>

  <div class="mt-3 min-w-0">
    <div class="truncate font-semibold text-white" title="<%= album.name %>">
      <%= link_to album.name, album_path(album), class: "hover:text-green-300" %>
    </div>
    <div class="mt-1 truncate text-sm text-neutral-400" title="<%= album.artist.name %>">
      <%= link_to album.artist.name, profile_path(album.artist.id), class: "hover:text-white" %>
    </div>
  </div>
</div>
