<% playlist_tracks = playlist.playlist_tracks.includes(track: [{ album: { cover_image_attachment: :blob } }, :user]).order(:position).map(&:track).compact %>
<% playlist_queue = player_tracks_payload(playlist_tracks) %>
<% first_track = playlist_tracks.first %>
<% first_track_audio_url = first_track&.audio_file&.attached? ? audio_track_path(first_track) : '' %>
<% first_track_metadata_url = first_track&.audio_file&.attached? ? metadata_track_path(first_track) : '' %>
<% first_track_liked = first_track.present? ? current_user.liked_track?(first_track) : false %>
<% playlist_image_url = first_track&.album&.cover_image&.attached? ? url_for(first_track.album.cover_image) : asset_path('default-music.svg') %>

<div data-controller="album-card"
     data-album-card-id-value="<%= first_track&.id %>"
     data-album-card-artist-value="<%= first_track&.user&.username || playlist.user.username %>"
     data-album-card-name-value="<%= first_track&.name || playlist.name %>"
     data-album-card-url-value="<%= first_track_audio_url %>"
     data-album-card-metadata-url-value="<%= first_track_metadata_url %>"
     data-album-card-duration-value="<%= first_track&.duration %>"
     data-album-card-image-value="<%= playlist_image_url %>"
     data-album-card-liked-value="<%= first_track_liked %>"
     data-album-card-like-url-value="<%= like_track_path(first_track) if first_track.present? %>"
     data-album-card-unlike-url-value="<%= unlike_track_path(first_track) if first_track.present? %>"
     data-album-card-queue-name-value="Плейлист: <%= playlist.name %>"
     data-album-card-queue-value="<%= playlist_queue.to_json %>"
     data-album-card-context-type-value="playlist"
     data-album-card-context-id-value="<%= playlist.id %>"
     data-album-card-context-url-value="<%= playlist_path(playlist) %>"
     data-album-card-play-icon-value="<%= asset_path('play.svg') %>"
     data-album-card-pause-icon-value="<%= asset_path('pause.svg') %>"
     class="playlist-card relative text-white bg-neutral-800 h-58 w-46 rounded-2xl flex flex-col justify-center items-center flex-shrink-0 overflow-hidden transition-all duration-200">
  <div class="cover-image group relative bg-neutral-700 h-36 w-40 rounded-2xl flex-shrink-0 flex items-center justify-center transition-all duration-200" data-album-card-target="artwork">
    <a href="<%= playlist_path(playlist) %>" class="block w-full h-full" title="<%= playlist.name %>">
      <% if first_track&.album&.cover_image&.attached? %>
        <%= image_tag first_track.album.cover_image, class: "w-full h-full object-cover rounded-2xl", alt: playlist.name %>
      <% else %>
        <%= image_tag 'default-music.svg', class: 'w-[70%] h-[70%] ml-[14%] mt-[14%]', alt: playlist.name %>
      <% end %>
    </a>

    <div class="absolute inset-0 flex items-end justify-between rounded-2xl bg-black/20 backdrop-blur-sm opacity-0 transition-opacity duration-300 group-hover:opacity-100 p-3 pointer-events-none">
      <button type="button"
              data-action="click->album-card#playTrack"
              class="pointer-events-auto hover:cursor-pointer rounded-full bg-neutral-900/90 p-1.5 hover:bg-neutral-700 transition-colors disabled:opacity-40 disabled:cursor-default"
              title="Воспроизвести плейлист"
              aria-label="Воспроизвести плейлист"
              <%= 'disabled' unless first_track.present? && first_track_audio_url.present? %>>
        <%= image_tag "play.svg", class: "w-8 h-8", data: { album_card_target: "playIcon" } %>
      </button>

      <% if local_assigns.fetch(:show_like, true) %>
        <%= render 'shared/playlist_like_button',
                   playlist: playlist,
                   button_class: 'pointer-events-auto hover:cursor-pointer rounded-full bg-neutral-900/90 p-1.5 hover:bg-neutral-700 transition-colors',
                   icon_class: 'w-8 h-8' %>
      <% else %>
        <span class="w-11 h-11"></span>
      <% end %>
    </div>
  </div>

  <div class="playlist-name mt-2 truncate w-40" title="<%= playlist.name %>">
    <%= link_to playlist.name, playlist_path(playlist), class: "hover:underline" %>
  </div>

  <div class="playlist-owner text-neutral-400 truncate w-40 hover:text-gray-400" title="<%= playlist.user.username %>">
    <%= link_to playlist.user.username, profile_path(playlist.user) %>
  </div>

  <div class="playlist-count text-neutral-500 text-xs truncate w-40" title="<%= playlist_tracks.size %> треков">
    <%= playlist_tracks.size %> треков
  </div>
</div>
