<div class="playlist-card relative text-white bg-neutral-800 h-58 w-46 rounded-2xl flex flex-col justify-center items-center flex-shrink-0 overflow-hidden">
  <div class="cover-image group relative bg-neutral-700 h-36 w-40 rounded-2xl flex-shrink-0 flex items-center justify-center">
    <%= image_tag 'default-music.svg', class: 'w-[70%] h-[70%]' %>

    <% if local_assigns.fetch(:show_like, true) %>
      <div class="absolute inset-0 flex items-end justify-end rounded-2xl bg-black/20 backdrop-blur-sm opacity-0 transition-opacity duration-300 group-hover:opacity-100 p-3">
        <%= render 'shared/playlist_like_button',
                   playlist: playlist,
                   button_class: 'pointer-events-auto hover:cursor-pointer rounded-full bg-neutral-900/90 p-1.5 hover:bg-neutral-700 transition-colors',
                   icon_class: 'w-8 h-8' %>
      </div>
    <% end %>
  </div>

  <div class="playlist-name mt-2 truncate w-40">
    <%= playlist.name %>
  </div>

  <div class="playlist-owner text-neutral-400 truncate w-40 hover:text-gray-400">
    <%= link_to playlist.user.username, profile_path(playlist.user) %>
  </div>
</div>
