<% track_audio_url = track.audio_file.attached? ? audio_track_path(track) : '' %>
<% track_metadata_url = track.audio_file.attached? ? metadata_track_path(track) : '' %>
<% track_image_url = track.album.cover_image.attached? ? url_for(track.album.cover_image) : asset_path('default-music.svg') %>
<% liked = current_user.liked_track?(track) %>

<div data-controller="track-card"
     data-track-card-id-value="<%= track.id %>"
     data-track-card-artist-value="<%= track.artist.name %>"
     data-track-card-name-value="<%= track.name %>"
     data-track-card-url-value="<%= track_audio_url %>"
     data-track-card-metadata-url-value="<%= track_metadata_url %>"
     data-track-card-duration-value="<%= track.duration %>"
     data-track-card-image-value="<%= track_image_url %>"
     data-track-card-liked-value="<%= liked %>"
     data-track-card-like-url-value="<%= like_track_path(track) %>"
     data-track-card-unlike-url-value="<%= unlike_track_path(track) %>"
     data-track-card-play-icon-value="<%= asset_path('play.svg') %>"
     data-track-card-pause-icon-value="<%= asset_path('pause.svg') %>"
     class="track-card relative text-white bg-neutral-800 h-58 w-46 rounded-2xl flex flex-col justify-center items-center flex-shrink-0 overflow-hidden transition-all duration-200">
  <div class="cover-image group relative bg-neutral-700 h-36 w-40 rounded-2xl flex-shrink-0 hover:cursor-pointer transition-all duration-200" data-track-card-target="artwork">
    <% if track.album.cover_image&.attached? %>
      <%= image_tag track.album.cover_image, class: "w-full h-full object-cover rounded-2xl", alt: track.name %>
    <% else %>
      <%= image_tag 'default-music.svg', class: "w-[70%] h-[70%] ml-[14%] mt-[14%]", alt: track.name %>
    <% end %>

    <div class="absolute inset-0 flex items-end justify-between rounded-2xl bg-black/20 backdrop-blur-sm opacity-0 transition-opacity duration-300 group-hover:opacity-100 p-3">
      <button type="button"
              data-action="click->track-card#playTrack"
              class="pointer-events-auto hover:cursor-pointer rounded-full bg-neutral-900/90 p-1.5 hover:bg-neutral-700 transition-colors"
              title="Воспроизвести">
        <%= image_tag "play.svg", class: "w-8 h-8", data: { track_card_target: "playIcon" } %>
      </button>

      <% if local_assigns.fetch(:show_like, true) %>
        <%= render 'shared/track_like_button',
                   track: track,
                   button_class: 'pointer-events-auto hover:cursor-pointer rounded-full bg-neutral-900/90 p-1.5 hover:bg-neutral-700 transition-colors',
                   icon_class: 'w-8 h-8' %>
      <% end %>
    </div>
  </div>

  <div class="track-name mt-2 truncate w-40" title="<%= track.name %>">
    <%= track.name %>
  </div>
  <div class="track-artist text-neutral-400 truncate w-40 hover:text-gray-400" title="<%= track.artist.name %>">
    <%= link_to track.artist.name, profile_path(track.artist.id) %>
  </div>
</div>
