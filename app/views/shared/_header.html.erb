<div id="main-header" class="header border-b border-solid border-b-neutral-800 pb-3 pt-2">
  <div class="header-container grid grid-cols-3 grid-rows-1 justify-between mt-2">
    <div class="logo ml-5">
      <%= link_to "MusicStreaming", pages_path, class: "text-white text-4xl font-bold" %>
    </div>

    <%= form_with url: search_path, method: :get, class: "search flex items-center justify-center w-140 h-10 bg-neutral-700 rounded-3xl overflow-hidden", data: { turbo_frame: "_top" } do |form| %>
      <%= form.search_field :q,
                            value: params[:q],
                            placeholder: "Трек, артист, альбом",
                            autocomplete: "off",
                            class: "w-full h-full pt-1 pl-3 rounded-l-3xl bg-neutral-700 text-white outline-none" %>
      <%= form.submit "Найти", class: "h-full px-4 bg-neutral-800 text-white hover:bg-neutral-600 hover:cursor-pointer transition-colors" %>
    <% end %>

    <div class="avatar flex justify-end mr-4 relative" data-controller="dropdown">
      <div class="w-12 h-12 rounded-2xl bg-neutral-700 flex items-center justify-center text-white font-bold hover:cursor-pointer"
           data-action="click->dropdown#toggle">
        <%= current_user.username.first&.upcase || "U" %>
      </div>

      <div data-dropdown-target="menu" class="hidden bg-neutral-800 absolute mt-10 z-50 right-0 min-h-80 w-56 rounded-xl shadow-xl/50">
        <div class="username text-2xl font-bold text-white px-3 py-2 border-b border-b-neutral-900 border-solid truncate">
          <%= current_user.username %>
        </div>
        <div class="studio text-lg"><%= link_to "Главная", pages_path, class: "text-white px-3 py-2 hover:text-red-300 block #{'bg-neutral-700' if controller_name == 'pages'}" %></div>
        <% if current_user.staff? %>
          <div class="studio text-lg"><%= link_to "Модерация", moderation_root_path, class: "text-white px-3 py-2 hover:text-red-300 block #{'bg-neutral-700' if controller_path.start_with?('moderation')}" %></div>
        <% end %>
        <% if current_user.admin? %>
          <div class="studio text-lg"><%= link_to "Админ-панель", admin_root_path, class: "text-white px-3 py-2 hover:text-red-300 block #{'bg-neutral-700' if controller_path.start_with?('admin')}" %></div>
        <% end %>
        <div class="studio text-lg"><%= link_to "Моя коллекция", collection_index_path, class: "text-white px-3 py-2 hover:text-red-300 block #{'bg-neutral-700' if controller_name == 'collection'}" %></div>
        <div class="studio text-lg"><%= link_to "Настройки аккаунта", profile_settings_path(current_user), class: "text-white px-3 py-2 hover:text-red-300 block #{'bg-neutral-700' if controller_name == 'profile' && action_name == 'settings'}" %></div>
        <div class="exit mt-13 text-lg"><%= button_to "Выйти", destroy_user_session_path, method: :delete, data: { turbo: false }, class: "text-white mt px-3 py-2 hover:text-red-300 cursor-pointer block" %></div>
      </div>
    </div>
  </div>
</div>
