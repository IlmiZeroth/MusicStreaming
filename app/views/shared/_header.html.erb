<div id="main-header" class = "header border-b border-solid border-b-neutral-800 pb-3 pt-2">
  <div class = "header-container grid grid-cols-3 grid-rows-1 justify-between mt-2 ">
    <div class = "logo ml-5">
      <%= link_to "MusicStreaming", pages_path, class: "text-white text-4xl font-bold" %>
    </div>
    <div class = "search flex justify-center w-140 h-10 bg-neutral-700 rounded-3xl">
      <input placeholder="Трек, артист, плейлист" class = "w-full h-full pt-1 pl-3 rounded-3xl text-white">
    </div>
    <div class = "avatar flex justify-end mr-4 relative" data-controller="dropdown">
      <% if current_user.avatar.attached? %>
        <%= image_tag current_user.avatar, class: "w-12 h-12 object-cover rounded-2xl hover: cursor-pointer", data: { action: "click->dropdown#toggle"} %>
      <% else %>
        <%= image_tag 'default-user.svg', class: "w-12 h-12 object-cover rounded-2xl hover: cursor-pointer", data: { action: "click->dropdown#toggle"} %>
      <% end %>
      <div data-dropdown-target="menu"
           class = "hidden bg-neutral-800 absolute mt-10 z-50 right-0 h-80 w-50 rounded-xl shadow-xl/50">
          <div class = "username text-2xl font-bold text-white px-3 py-2 border-b border-b-neutral-900 border-solid truncate hover:text-neutral-200"> <%= link_to current_user.username, profile_path(current_user) %></div>
          <div class = "studio text-lg"> <%= link_to "Главная", pages_path, class: "text-white px-3 py-2 hover:text-red-300 block #{'bg-neutral-700' if controller_name == 'pages'}" %> </div>
          <div class = "studio text-lg"> <%= link_to "Моя студия", studio_path, class: "text-white px-3 py-2 hover:text-red-300 block #{'bg-neutral-700' if controller_name == 'studio'}" %> </div>
          <div class = "studio text-lg"> <%= link_to "Настройки", profile_settings_path(current_user), class: "text-white px-3 py-2 hover:text-red-300 block #{'bg-neutral-700' if controller_name == 'profile' && action_name == 'settings'}" %> </div>
          <div class = "exit mt-25 text-lg"> <%= button_to "Выйти", destroy_user_session_path, method: :delete, data: { turbo: false }, class: "text-white mt px-3 py-2 hover:text-red-300 cursor-pointer block" %> </div>
    </div>
  </div>
</div>
</div>