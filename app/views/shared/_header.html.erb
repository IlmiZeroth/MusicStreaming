<header id="main-header" class="sticky top-0 z-40 border-b border-neutral-800/80 bg-neutral-950/90 backdrop-blur-xl">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-3 px-4 py-3 sm:px-6 lg:flex-row lg:items-center lg:gap-5 lg:px-8">
    <div class="flex items-center justify-between gap-3">
      <%= link_to pages_path, class: "group inline-flex items-center gap-3" do %>
        <span class="flex h-11 w-11 overflow-hidden rounded-2xl bg-neutral-900 ring-1 ring-neutral-800 transition group-hover:ring-green-400/70">
          <%= image_tag "site-icon.png", class: "h-full w-full object-cover", alt: "MusicStreaming" %>
        </span>
        <span class="text-lg font-black tracking-tight text-white sm:text-xl">MusicStreaming</span>
      <% end %>

      <div class="lg:hidden" data-controller="dropdown">
        <button type="button" data-action="click->dropdown#toggle" class="flex h-11 w-11 overflow-hidden rounded-2xl bg-neutral-900 text-sm font-bold ring-1 ring-neutral-800">
          <%= image_tag user_avatar_url(current_user), class: "h-full w-full object-cover", alt: current_user.username %>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-4 top-16 z-50 w-64 overflow-hidden rounded-3xl border border-neutral-800 bg-neutral-950/95 shadow-2xl shadow-black/40 backdrop-blur">
          <%= render "shared/header_menu" %>
        </div>
      </div>
    </div>

    <%= form_with url: search_path,
                  method: :get,
                  class: "relative order-3 min-w-0 flex-1 lg:order-none",
                  data: { controller: "live-search", live_search_url_value: search_suggestions_path, turbo_frame: "_top" } do |form| %>
      <div class="flex overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/80 ring-0 transition focus-within:border-green-400/70 focus-within:ring-2 focus-within:ring-green-400/20">
        <%= form.search_field :q,
                              value: params[:q],
                              placeholder: "Трек, артист, альбом",
                              autocomplete: "off",
                              class: "min-w-0 flex-1 bg-transparent px-4 py-3 text-sm text-white outline-none placeholder:text-neutral-500",
                              data: { live_search_target: "input", action: "input->live-search#queue focus->live-search#queue keydown->live-search#keydown" } %>
        <%= form.submit "Найти", class: "shrink-0 bg-neutral-800 px-4 text-sm font-semibold text-white transition hover:bg-neutral-700 hover:cursor-pointer sm:px-5" %>
      </div>
      <div data-live-search-target="results" class="hidden absolute left-0 right-0 top-full z-50 mt-2 max-h-[70vh] overflow-y-auto rounded-3xl border border-neutral-800 bg-neutral-950/98 p-2 shadow-2xl shadow-black/60 backdrop-blur"></div>
    <% end %>

    <nav class="order-2 flex items-center gap-1 overflow-x-auto pb-1 lg:order-none lg:pb-0">
      <%= link_to "Главная", pages_path, class: nav_link_class(controller_name == "pages") %>
      <%= link_to "Коллекция", collection_index_path, class: nav_link_class(controller_name == "collection") %>
      <% if current_user.staff? %>
        <%= link_to "Модерация", moderation_root_path, class: nav_link_class(controller_path.start_with?("moderation")) %>
      <% end %>
      <% if current_user.admin? %>
        <%= link_to "Админ", admin_root_path, class: nav_link_class(controller_path.start_with?("admin")) %>
      <% end %>
    </nav>

    <div class="relative hidden lg:block" data-controller="dropdown">
      <button type="button" data-action="click->dropdown#toggle" class="flex items-center gap-3 rounded-2xl border border-neutral-800 bg-neutral-900/80 px-3 py-2 text-left transition hover:border-neutral-700 hover:bg-neutral-900">
        <span class="flex h-9 w-9 overflow-hidden rounded-xl bg-neutral-800 text-sm font-bold text-white">
          <%= image_tag user_avatar_url(current_user), class: "h-full w-full object-cover", alt: current_user.username %>
        </span>
        <span class="hidden min-w-0 xl:block">
          <span class="block max-w-32 truncate text-sm font-semibold text-white"><%= current_user.username %></span>
          <span class="block text-xs text-neutral-500"><%= current_user.role_label %></span>
        </span>
      </button>
      <div data-dropdown-target="menu" class="hidden absolute right-0 top-14 z-50 w-72 overflow-hidden rounded-3xl border border-neutral-800 bg-neutral-950/95 shadow-2xl shadow-black/40 backdrop-blur">
        <%= render "shared/header_menu" %>
      </div>
    </div>
  </div>
</header>
