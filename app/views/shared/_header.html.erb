<div id="main-header" data-turbo-permanent class = "header border-b border-solid border-b-neutral-800 pb-3 pt-2">
  <div class = "header-container flex justify-between mt-2 ">
    <div class = "logo ml-5">
      <%= link_to "MusicStreaming", pages_path, class: "text-white text-4xl font-bold" %>
    </div>
    <div class = "search w-140 h-10 bg-neutral-700 rounded-3xl">
      <input placeholder="Трек, артист, плейлист" class = "w-full h-full pt-1 pl-3 rounded-3xl text-white">
    </div>
    <div class = "avatar mr-4 relative" data-controller="dropdown">
      <button data-action="click->dropdown#toggle", class="hover: cursor-pointer">
        <%= image_tag 'default-user.svg', alt: 'User Avatar', height: 48, width: 48 %>
      </button>
      <div data-dropdown-target="menu"
           class = "hidden bg-neutral-800 absolute z-50 right-0 h-60 w-50 rounded-xl">
        <div class = "username text-2xl font-bold text-white px-3 py-2 border-b border-b-neutral-900 border-solid truncate w-50"><%= current_user.username %></div>
        <% if controller_name == "pages" %>
          <div class = "studio mt-5 text-lg"> <%= link_to "Моя студия", studio_path, class: "text-white px-3 py-2 hover:text-red-300" %> </div>
        <% else %>
          <div class = "studio mt-5 text-lg"> <%= link_to "Главная", pages_path, class: "text-white px-3 py-2 hover:text-red-300" %> </div>
      <% end %>
        <div class = "exit mt-25 text-lg"> <%= button_to "Выйти", destroy_user_session_path, method: :delete, class: "text-white mt px-3 py-2 hover:text-red-300 cursor-pointer " %> </div>
    </div>
  </div>
</div>
</div>