<%= render "shared/header" %>
<% playlist_queue = player_tracks_payload(@tracks) %>
<% first_playlist_track = playlist_queue.first %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <button type="button" data-controller="smart-back" data-action="click->smart-back#goBack" data-smart-back-fallback-url-value="<%= collection_index_path %>" class="mb-5 inline-flex items-center gap-2 rounded-2xl bg-neutral-950/70 px-3 py-2 text-sm text-neutral-300 ring-1 ring-neutral-800 transition hover:bg-neutral-800 hover:text-white">
      <%= image_tag 'left.svg', class: "h-4 w-4" %> Назад
    </button>

    <div class="grid gap-6 md:grid-cols-[12rem_1fr] md:items-end">
      <div class="aspect-square overflow-hidden rounded-[2rem] bg-neutral-800 ring-1 ring-neutral-800">
        <% if @playlist.cover_image.attached? %>
          <%= image_tag @playlist.cover_image, class: "h-full w-full object-cover", alt: @playlist.name %>
        <% elsif @tracks.first&.album&.cover_image&.attached? %>
          <%= image_tag @tracks.first.album.cover_image, class: "h-full w-full object-cover", alt: @playlist.name %>
        <% else %>
          <div class="flex h-full w-full items-center justify-center p-10"><%= image_tag 'default-music.svg', class: "h-full w-full", alt: @playlist.name %></div>
        <% end %>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Плейлист</p>
        <h1 class="mt-2 truncate text-4xl font-black tracking-tight text-white sm:text-5xl" title="<%= @playlist.name %>"><%= @playlist.name %></h1>
        <% if @playlist.description.present? %><p class="mt-3 max-w-3xl text-neutral-400"><%= @playlist.description %></p><% end %>
        <div class="mt-5 flex flex-wrap gap-2 text-sm text-neutral-300"><span class="rounded-full bg-neutral-950/70 px-3 py-1.5 ring-1 ring-neutral-800"><%= @playlist.user.username %></span><span class="rounded-full bg-neutral-950/70 px-3 py-1.5 ring-1 ring-neutral-800"><%= number_with_delimiter @tracks.size %> треков</span></div>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <% if first_playlist_track.present? %>
            <button type="button" data-controller="album-card" data-action="click->album-card#playTrack" data-album-card-id-value="<%= first_playlist_track[:id] %>" data-album-card-artist-value="<%= first_playlist_track[:artist] %>" data-album-card-name-value="<%= first_playlist_track[:name] %>" data-album-card-url-value="<%= first_playlist_track[:url] %>" data-album-card-metadata-url-value="<%= first_playlist_track[:metadataUrl] %>" data-album-card-duration-value="<%= first_playlist_track[:duration] %>" data-album-card-image-value="<%= first_playlist_track[:image] %>" data-album-card-liked-value="<%= first_playlist_track[:liked] %>" data-album-card-like-url-value="<%= first_playlist_track[:likeUrl] %>" data-album-card-unlike-url-value="<%= first_playlist_track[:unlikeUrl] %>" data-album-card-queue-name-value="Плейлист: <%= @playlist.name %>" data-album-card-queue-value="<%= playlist_queue.to_json %>" data-album-card-context-type-value="playlist" data-album-card-context-id-value="<%= @playlist.id %>" data-album-card-context-url-value="<%= playlist_path(@playlist) %>" data-album-card-play-icon-value="<%= asset_path('play.svg') %>" data-album-card-pause-icon-value="<%= asset_path('pause.svg') %>" class="inline-flex items-center gap-2 rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300" title="Воспроизвести плейлист"><%= image_tag "play.svg", class: "h-5 w-5", data: { album_card_target: "playIcon" } %> Слушать</button>
          <% else %>
            <button type="button" disabled class="inline-flex items-center gap-2 rounded-2xl bg-neutral-800 px-5 py-3 font-bold text-neutral-500 cursor-not-allowed"><%= image_tag "play.svg", class: "h-5 w-5 opacity-50" %> Слушать</button>
          <% end %>
          <%= render 'shared/playlist_like_button', playlist: @playlist, button_class: 'flex h-12 w-12 items-center justify-center rounded-2xl border border-neutral-700 bg-neutral-950/70 transition hover:bg-neutral-800', icon_class: 'h-7 w-7' %>
          <% if @show_actions %>
            <%= link_to "Редактировать", edit_playlist_path(@playlist), class: "rounded-2xl border border-neutral-700 bg-neutral-950/70 px-5 py-3 font-semibold text-white transition hover:bg-neutral-800" %>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-8">
    <div class="mb-4"><p class="text-sm text-neutral-500">Очередь</p><h2 class="text-2xl font-bold text-white">Треки</h2></div>
    <% if @tracks.present? %>
      <div class="flex flex-col gap-3" data-playback-queue-name-value="Плейлист: <%= @playlist.name %>" data-playback-context-type-value="playlist" data-playback-context-id-value="<%= @playlist.id %>" data-playback-context-url-value="<%= playlist_path(@playlist) %>">
        <% @tracks.each do |track| %><%= render "shared/track", track: track %><% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "В плейлисте пока нет треков", description: "Сохраните очередь из плеера, чтобы быстро собрать новый плейлист." %>
    <% end %>
  </section>
</main>
