<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Пользователи</p>
        <h1 class="mt-2 text-3xl font-black text-white sm:text-4xl">Управление аккаунтами</h1>
        <p class="mt-2 text-neutral-400">Администратор может менять данные аккаунта, пароль, аватар, роли и удалять пользователей.</p>
      </div>
      <%= link_to "Назад", admin_root_path, class: secondary_button_class %>
    </div>
  </section>

  <section class="mt-6 rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-4 sm:p-6">
<%= render "shared/pagination_filter", label: "Поиск пользователей", placeholder: "Имя, email или ID" %>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[860px] text-left text-sm">
        <thead class="border-b border-neutral-800 text-neutral-500">
          <tr>
            <th class="py-3 font-medium">Пользователь</th>
            <th class="font-medium">Email</th>
            <th class="font-medium">Роль</th>
            <th class="font-medium">Создан</th>
            <th></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-800/80">
          <% @users.each do |user| %>
            <tr>
              <td class="py-3">
                <div class="flex items-center gap-3">
                  <%= image_tag user_avatar_url(user), class: "h-10 w-10 rounded-2xl object-cover ring-1 ring-neutral-800", alt: user.username %>
                  <div class="min-w-0">
                    <div class="truncate font-semibold text-white"><%= user.username %> <%= "(вы)" if user == current_user %></div>
                    <div class="text-xs text-neutral-500">ID <%= user.id %></div>
                  </div>
                </div>
              </td>
              <td class="text-neutral-300"><%= user.email %></td>
              <td><span class="rounded-full bg-neutral-950 px-3 py-1 text-neutral-300 ring-1 ring-neutral-800"><%= user.role_label %></span></td>
              <td class="text-neutral-500"><%= l(user.created_at, format: :short) rescue user.created_at.strftime("%d.%m.%Y") %></td>
              <td class="py-3 text-right">
                <div class="flex justify-end gap-3">
                  <%= link_to "Редактировать", edit_admin_user_path(user), class: "text-neutral-300 hover:text-white" %>
                  <% unless user == current_user %>
                    <%= button_to "Удалить", admin_user_path(user), method: :delete, data: { turbo_confirm: "Удалить аккаунт #{user.username}?" }, class: "text-red-300 hover:text-red-200 cursor-pointer" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @users.empty? %>
            <tr><td colspan="5" class="py-8 text-neutral-400">Пользователей не найдено.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%= render "shared/pagination", pagination: @pagination %>
  </section>
</main>
