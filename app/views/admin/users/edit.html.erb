<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <div class="mx-auto max-w-3xl">
    <div class="mb-5 flex items-center justify-between gap-3">
      <h1 class="text-3xl font-black text-white">Редактирование пользователя</h1>
      <%= link_to "Назад", admin_users_path, class: secondary_button_class %>
    </div>

    <% if @user.errors.any? %>
      <div class="mb-4 rounded-2xl border border-red-400/60 bg-red-500/10 p-4 text-red-100"><%= @user.errors.full_messages.to_sentence %></div>
    <% end %>

    <%= form_with model: [:admin, @user], method: :patch, local: true, html: { multipart: true, class: "grid gap-5 rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7" } do |f| %>
      <div data-controller="preview" data-preview-default-url-value="<%= user_avatar_url(@user) %>" class="flex flex-col gap-4 sm:flex-row sm:items-center">
        <%= image_tag user_avatar_url(@user), class: "h-24 w-24 rounded-[1.5rem] object-cover ring-1 ring-neutral-800", alt: @user.username, data: { preview_target: "preview" } %>
        <div class="flex-1">
          <%= f.label :avatar, "Аватар", class: "mb-2 block text-sm text-neutral-400" %>
          <%= f.file_field :avatar, accept: "image/*", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-sm text-white file:mr-4 file:rounded-xl file:border-0 file:bg-neutral-800 file:px-3 file:py-2 file:text-white", data: { preview_target: "input", action: "change->preview#preview" } %>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= f.label :username, "Имя пользователя", class: "mb-2 block text-sm text-neutral-400" %>
          <%= f.text_field :username, required: true, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400" %>
        </div>
        <div>
          <%= f.label :email, "Email", class: "mb-2 block text-sm text-neutral-400" %>
          <%= f.email_field :email, required: true, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400" %>
        </div>
      </div>

      <div>
        <%= f.label :user_role, "Роль", class: "mb-2 block text-sm text-neutral-400" %>
        <%= f.select :user_role, User.role_options, {}, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400" %>
        <% if @user == current_user %><p class="mt-2 text-xs text-neutral-500">Свою роль менять нельзя.</p><% end %>
      </div>

      <div class="rounded-[1.5rem] border border-neutral-800 bg-neutral-950/40 p-4">
        <h2 class="text-lg font-bold text-white">Сменить пароль</h2>
        <p class="mt-1 text-sm text-neutral-500">Оставьте поля пустыми, если пароль менять не нужно.</p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :password, "Новый пароль", class: "mb-2 block text-sm text-neutral-400" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-900 px-4 py-3 text-white outline-none focus:border-green-400" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "Подтверждение", class: "mb-2 block text-sm text-neutral-400" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-900 px-4 py-3 text-white outline-none focus:border-green-400" %>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <%= f.submit "Сохранить", class: "rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300 cursor-pointer" %>
        <%= link_to "Отмена", admin_users_path, class: "rounded-2xl border border-neutral-700 bg-neutral-950/70 px-5 py-3 text-center font-semibold text-white transition hover:bg-neutral-800" %>
      </div>
    <% end %>
  </div>
</main>
