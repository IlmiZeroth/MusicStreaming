<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Внутренние письма</p>
        <h1 class="mt-2 text-3xl font-black text-white sm:text-4xl">Письма администратора</h1>
      </div>
      <div class="flex flex-wrap gap-2">
        <% if @unread_count.positive? %>
          <span class="inline-flex items-center rounded-2xl bg-green-400/10 px-4 py-2 text-sm font-semibold text-green-200 ring-1 ring-green-400/30"><%= @unread_count %> непрочит.</span>
        <% end %>
        <%= link_to "Назад", admin_root_path, class: secondary_button_class %>
      </div>
    </div>
  </section>

  <section class="mt-6 rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-4 sm:p-6">
<%= render "shared/pagination_filter", label: "Поиск писем", placeholder: "Email, тема, текст письма или тип" %>
    <% if @messages.any? %>
      <div class="grid gap-3">
        <% @messages.each do |message| %>
          <%= link_to admin_mail_message_path(message), class: "block rounded-[1.5rem] border px-4 py-4 transition hover:border-green-400/50 hover:bg-neutral-900 #{message.read? ? 'border-neutral-800 bg-neutral-950/40' : 'border-green-400/30 bg-green-400/5'}" do %>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <% unless message.read? %>
                    <span class="h-2 w-2 rounded-full bg-green-400"></span>
                  <% end %>
                  <h2 class="truncate text-base font-bold text-white"><%= message.subject %></h2>
                  <span class="rounded-full bg-neutral-900 px-2.5 py-1 text-xs text-neutral-400 ring-1 ring-neutral-800"><%= message.message_type %></span>
                </div>
                <p class="mt-2 text-sm text-neutral-400">Кому: <span class="text-neutral-200"><%= message.recipient_email %></span></p>
                <p class="mt-1 line-clamp-2 text-sm text-neutral-500"><%= message.body %></p>
              </div>
              <div class="shrink-0 text-sm text-neutral-500"><%= l(message.created_at, format: :short) rescue message.created_at.strftime("%d.%m.%Y %H:%M") %></div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "Писем пока нет", description: "Когда пользователь запросит восстановление пароля, сообщение появится здесь (это временное решение)." %>
    <% end %>
    <%= render "shared/pagination", pagination: @pagination %>
  </section>
</main>
