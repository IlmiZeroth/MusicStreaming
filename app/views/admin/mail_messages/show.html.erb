<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <div class="mx-auto max-w-4xl">
    <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Внутреннее письмо</p>
        <h1 class="mt-2 text-3xl font-black text-white"><%= @message.subject %></h1>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "Назад", admin_mail_messages_path, class: secondary_button_class %>
        <%= button_to "Удалить", admin_mail_message_path(@message), method: :delete, data: { turbo_confirm: "Удалить это письмо?" }, class: "inline-flex items-center justify-center rounded-2xl border border-red-500/50 bg-red-500/10 px-4 py-2 font-medium text-red-200 transition hover:bg-red-500/20 cursor-pointer" %>
      </div>
    </div>

    <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
      <div class="grid gap-4 text-sm sm:grid-cols-2">
        <div class="rounded-2xl border border-neutral-800 bg-neutral-950/50 p-4">
          <div class="text-neutral-500">Получатель</div>
          <div class="mt-1 font-semibold text-white"><%= @message.recipient_email %></div>
          <% if @message.recipient.present? %>
            <div class="mt-1 text-neutral-400">Аккаунт: <%= @message.recipient.username %> · ID <%= @message.recipient.id %></div>
          <% end %>
        </div>
        <div class="rounded-2xl border border-neutral-800 bg-neutral-950/50 p-4">
          <div class="text-neutral-500">Создано</div>
          <div class="mt-1 font-semibold text-white"><%= l(@message.created_at, format: :long) rescue @message.created_at.strftime("%d.%m.%Y %H:%M") %></div>
          <div class="mt-1 text-neutral-400"><%= @message.read? ? "Прочитано" : "Новое" %></div>
        </div>
      </div>

      <% if @message.reset_url.present? %>
        <div class="mt-5 rounded-[1.5rem] border border-green-400/30 bg-green-400/10 p-4">
          <div class="text-sm font-semibold text-green-200">Ссылка восстановления пароля</div>
          <p class="mt-2 break-all text-sm text-green-100"><%= @message.reset_url %></p>
          <div class="mt-4 flex flex-wrap gap-2">
            <%= link_to "Открыть ссылку", @message.reset_url, target: "_blank", rel: "noopener", class: primary_button_class %>
          </div>
        </div>
      <% end %>

      <div class="mt-5 rounded-[1.5rem] border border-neutral-800 bg-neutral-950/60 p-5">
        <h2 class="mb-3 text-lg font-bold text-white">Текст письма</h2>
        <div class="prose prose-invert max-w-none text-neutral-200 prose-a:text-green-300">
          <%= simple_format(@message.body) %>
        </div>
      </div>

      <% if @message.metadata.present? %>
        <details class="mt-5 rounded-[1.5rem] border border-neutral-800 bg-neutral-950/40 p-4 text-sm text-neutral-400">
          <summary class="cursor-pointer font-semibold text-neutral-200">Технические данные</summary>
          <pre class="mt-3 overflow-x-auto whitespace-pre-wrap text-xs"><%= JSON.pretty_generate(@message.metadata || {}) %></pre>
        </details>
      <% end %>
    </section>
  </div>
</main>
