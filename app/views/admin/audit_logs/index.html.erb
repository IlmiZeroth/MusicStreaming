<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div><p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Аудит</p><h1 class="mt-2 text-3xl font-black text-white sm:text-4xl">Журнал действий</h1><p class="mt-2 text-neutral-400">Все действия модерации и администрирования.</p></div>
      <%= link_to "Назад", admin_root_path, class: secondary_button_class %>
    </div>
  </section>

  <section class="mt-6 rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-4 sm:p-6">
<%= render "shared/pagination_filter", label: "Поиск по журналу", placeholder: "Действие, пользователь, объект, IP или данные" %>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[980px] text-left text-sm align-top">
        <thead class="border-b border-neutral-800 text-neutral-500"><tr><th class="py-3 font-medium">Дата</th><th class="font-medium">Кто</th><th class="font-medium">Действие</th><th class="font-medium">Объект</th><th class="font-medium">Данные</th><th class="font-medium">IP</th></tr></thead>
        <tbody class="divide-y divide-neutral-800/80">
          <% @logs.each do |log| %>
            <tr>
              <td class="py-3 whitespace-nowrap text-neutral-300"><%= l(log.created_at, format: :short) %></td>
              <td class="text-white"><%= log.actor_name %></td>
              <td class="text-neutral-300"><%= log.action %></td>
              <td class="text-neutral-400"><%= log.auditable_name %></td>
              <td class="max-w-xl text-neutral-500"><pre class="whitespace-pre-wrap text-xs"><%= JSON.pretty_generate(log.metadata || {}) %></pre></td>
              <td class="text-neutral-500"><%= log.ip_address %></td>
            </tr>
          <% end %>
          <% if @logs.empty? %><tr><td colspan="6" class="py-8 text-neutral-400">Логов пока нет.</td></tr><% end %>
        </tbody>
      </table>
    </div>
    <%= render "shared/pagination", pagination: @pagination %>
  </section>
</main>
