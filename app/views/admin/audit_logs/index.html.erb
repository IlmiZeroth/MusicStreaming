<%= render "shared/header" %>

<div class="text-white px-6 py-6 mb-28">
  <div class="flex items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-3xl font-bold">Журнал действий</h1>
      <p class="text-neutral-400 mt-1">Последние 200 действий модерации и администрирования.</p>
    </div>
    <%= link_to "Назад в админ-панель", admin_root_path, class: "bg-neutral-800 hover:bg-neutral-700 px-4 py-2 rounded-2xl" %>
  </div>

  <div class="bg-neutral-800 rounded-2xl p-5 overflow-x-auto">
    <table class="w-full text-left align-top">
      <thead class="text-neutral-400 border-b border-neutral-700">
        <tr><th class="py-2">Дата</th><th>Кто</th><th>Действие</th><th>Объект</th><th>Данные</th><th>IP</th></tr>
      </thead>
      <tbody>
        <% @logs.each do |log| %>
          <tr class="border-b border-neutral-700/60">
            <td class="py-3 text-neutral-300 whitespace-nowrap"><%= l(log.created_at, format: :short) %></td>
            <td><%= log.actor_name %></td>
            <td><%= log.action %></td>
            <td class="text-neutral-300"><%= log.auditable_name %></td>
            <td class="text-neutral-400 max-w-xl"><pre class="whitespace-pre-wrap text-xs"><%= JSON.pretty_generate(log.metadata || {}) %></pre></td>
            <td class="text-neutral-400"><%= log.ip_address %></td>
          </tr>
        <% end %>
        <% if @logs.empty? %>
          <tr><td colspan="6" class="py-6 text-neutral-400">Логов пока нет.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
