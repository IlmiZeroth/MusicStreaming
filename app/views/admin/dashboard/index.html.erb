<%= render "shared/header" %>

<div class="text-white px-6 py-6 mb-28">
  <div class="flex items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-3xl font-bold">Админ-панель</h1>
      <p class="text-neutral-400 mt-1">Управление ролями и журналом действий.</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Пользователи", admin_users_path, class: "bg-green-500 hover:bg-green-400 text-black px-4 py-2 rounded-2xl" %>
      <%= link_to "Логи", admin_audit_logs_path, class: "bg-neutral-800 hover:bg-neutral-700 px-4 py-2 rounded-2xl" %>
      <%= link_to "Модерация", moderation_root_path, class: "bg-neutral-800 hover:bg-neutral-700 px-4 py-2 rounded-2xl" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8">
    <div class="bg-neutral-800 rounded-2xl p-4"><div class="text-neutral-400">Пользователи</div><div class="text-3xl font-bold"><%= @users_count %></div></div>
    <div class="bg-neutral-800 rounded-2xl p-4"><div class="text-neutral-400">Модераторы</div><div class="text-3xl font-bold"><%= @moderators_count %></div></div>
    <div class="bg-neutral-800 rounded-2xl p-4"><div class="text-neutral-400">Админы</div><div class="text-3xl font-bold"><%= @admins_count %></div></div>
    <div class="bg-neutral-800 rounded-2xl p-4"><div class="text-neutral-400">Артисты</div><div class="text-3xl font-bold"><%= @artists_count %></div></div>
    <div class="bg-neutral-800 rounded-2xl p-4"><div class="text-neutral-400">Альбомы</div><div class="text-3xl font-bold"><%= @albums_count %></div></div>
    <div class="bg-neutral-800 rounded-2xl p-4"><div class="text-neutral-400">Треки</div><div class="text-3xl font-bold"><%= @tracks_count %></div></div>
  </div>

  <div class="bg-neutral-800 rounded-2xl p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold">Последние действия</h2>
      <%= link_to "Все логи", admin_audit_logs_path, class: "text-green-400 hover:text-green-300" %>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead class="text-neutral-400 border-b border-neutral-700">
          <tr><th class="py-2">Дата</th><th>Кто</th><th>Действие</th><th>Объект</th></tr>
        </thead>
        <tbody>
          <% @recent_logs.each do |log| %>
            <tr class="border-b border-neutral-700/60">
              <td class="py-2 text-neutral-300"><%= l(log.created_at, format: :short) %></td>
              <td><%= log.actor_name %></td>
              <td><%= log.action %></td>
              <td class="text-neutral-300"><%= log.auditable_name %></td>
            </tr>
          <% end %>
          <% if @recent_logs.empty? %>
            <tr><td colspan="4" class="py-6 text-neutral-400">Логов пока нет.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
