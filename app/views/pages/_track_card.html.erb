<div data-controller="track-card"
     data-track-card-artist-value="<%= track.user.username %>"
     data-track-card-name-value="<%= track.name %>"
     data-track-card-url-value="<%= url_for track.audio_file %>"
     data-track-card-image-value="<%= url_for track.album.cover_image %>>"
  class = "track-card bg-neutral-800 h-58 w-46 rounded-2xl flex flex-col justify-center items-center flex-shrink-0">
  <div data-action="click->track-card#playTrack"
    class = "cover-image relative bg-neutral-700 h-36 w-40 rounded-2xl flex-shrink-0 hover: cursor-pointer ">
    <% if track.album.cover_image&.attached? %>
      <%= image_tag track.album.cover_image, class: "w-full h-full object-cover rounded-2xl" %>
    <% else %>
      <%= image_tag 'default-music.svg', class: "w-[70%] h-[70%] ml-[14%] mt-[14%]" %>
    <% end %>
    <div class = "absolute inset-0 flex justify-center items-center rounded-2xl backdrop-blur-sm opacity-0 transition-opacity duration-300 hover:opacity-100">
      <%= show_svg "play.svg", width: 40, height: 40, fill: "#FFFFFF"%>
    </div>
  </div>
  <div class = "track-name mt-2 truncate w-40">
    <%= track.name %>
  </div>
  <div class = "track-artist text-neutral-400 truncate w-40">
    <%= track.user.username %>
  </div>

</div>