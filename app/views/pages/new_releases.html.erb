<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <button type="button"
            data-controller="smart-back"
            data-action="click->smart-back#goBack"
            data-smart-back-fallback-url-value="<%= pages_path %>"
            class="mb-5 inline-flex items-center gap-2 rounded-2xl bg-neutral-950/70 px-3 py-2 text-sm text-neutral-300 ring-1 ring-neutral-800 transition hover:bg-neutral-800 hover:text-white">
      <%= image_tag "left.svg", class: "h-4 w-4" %> Назад на главную
    </button>

    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Новые 100</p>
    <h1 class="mt-2 text-3xl font-black text-white sm:text-4xl">Новые треки</h1>
    <p class="mt-2 text-neutral-400">Сто последних добавленных треков в каталоге.</p>
  </section>

  <% if @tracks.present? %>
    <section class="mt-6" data-playback-queue-name-value="100 новых треков" data-playback-context-type-value="chart" data-playback-context-id-value="new" data-playback-context-url-value="<%= new_tracks_path %>">
      <div class="flex flex-col gap-3">
        <% @tracks.each_with_index do |track, index| %>
          <%= render "shared/ranked_track", track: track, index: index + 1 %>
        <% end %>
      </div>
    </section>
  <% else %>
    <%= render "shared/empty_state", title: "Новинок пока нет", description: "Когда модераторы загрузят треки, они появятся здесь." %>
  <% end %>
</main>
