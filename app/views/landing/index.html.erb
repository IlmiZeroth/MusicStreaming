<% content_for :title, "MusicStreaming — слушайте музыку без лишнего шума" %>
<% featured_track_title = @featured_track&.name || "Треки скоро появятся" %>
<% featured_track_artist = @featured_track&.artist&.name || "Каталог ещё пуст" %>
<% featured_track_cover = if @featured_track&.album&.cover_image&.attached?
  url_for(@featured_track.album.cover_image)
else
  asset_path("default-music.svg")
end %>

<main class="landing-gradient relative min-h-screen w-full max-w-full overflow-hidden overflow-x-hidden text-white">
  <div aria-hidden="true" class="landing-orb left-[-4rem] top-24 h-56 w-56 bg-green-400/25"></div>
  <div aria-hidden="true" class="landing-orb right-[-5rem] top-16 h-72 w-72 bg-[#4F4A85]/40"></div>
  <div aria-hidden="true" class="landing-orb bottom-[-6rem] left-1/2 h-72 w-72 bg-fuchsia-500/15"></div>

  <header class="relative z-10 mx-auto flex w-full max-w-7xl min-w-0 flex-col gap-4 px-4 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
    <%= link_to root_path, class: "inline-flex min-w-0 max-w-full items-center gap-3" do %>
      <span class="flex h-11 w-11 shrink-0 overflow-hidden rounded-2xl bg-neutral-900/80 ring-1 ring-white/10">
        <%= image_tag "site-icon.png", class: "h-full w-full object-cover", alt: "MusicStreaming" %>
      </span>
      <span class="min-w-0 truncate text-lg font-black tracking-tight sm:text-xl">MusicStreaming</span>
    <% end %>

    <div class="grid w-full min-w-0 max-w-full grid-cols-2 gap-2 sm:flex sm:w-auto sm:items-center sm:justify-end">
      <% if user_signed_in? %>
        <%= link_to "Открыть музыку", pages_path, class: "col-span-2 inline-flex min-w-0 items-center justify-center rounded-2xl bg-green-400 px-4 py-2.5 text-sm font-bold text-black transition hover:bg-green-300 sm:col-span-1" %>
      <% else %>
        <%= link_to "Войти", new_user_session_path, class: "inline-flex min-w-0 items-center justify-center rounded-2xl px-4 py-2.5 text-sm font-semibold text-neutral-300 ring-1 ring-white/10 transition hover:bg-white/5 hover:text-white" %>
        <%= link_to new_user_registration_path, class: "inline-flex min-w-0 items-center justify-center rounded-2xl bg-green-400 px-4 py-2.5 text-sm font-bold text-black transition hover:bg-green-300" do %>
          <span class="sm:hidden">Создать</span>
          <span class="hidden sm:inline">Создать аккаунт</span>
        <% end %>
      <% end %>
    </div>
  </header>

  <section class="relative z-10 mx-auto grid w-full max-w-7xl min-w-0 grid-cols-1 items-center gap-8 px-4 pb-14 pt-4 sm:min-h-[calc(100vh-5.5rem)] sm:gap-10 sm:px-6 sm:pt-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:px-8">
    <div class="min-w-0 max-w-full">
      <h1 class="max-w-full break-words text-[2.25rem] font-black leading-[1.08] tracking-tight sm:text-6xl lg:text-7xl">
        Слушай музыку с Music Streaming
      </h1>
      <p class="mt-5 max-w-2xl break-words text-base leading-7 text-neutral-300 sm:mt-6 sm:text-lg sm:leading-8">
        Музыка, которая всегда под рукой. Ищи треки, открывай новых артистов, собирай свои плейлисты и слушай так, как удобно тебе
      </p>
      <div class="mt-7 flex flex-col gap-3 sm:mt-8 sm:flex-row">
        <% if user_signed_in? %>
          <%= link_to "Перейти к каталогу", pages_path, class: "inline-flex w-full items-center justify-center rounded-2xl bg-green-400 px-6 py-3 font-bold text-black transition hover:bg-green-300 sm:w-auto" %>
          <%= link_to "Моя коллекция", collection_index_path, class: "inline-flex w-full items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-6 py-3 font-semibold text-white transition hover:bg-white/10 sm:w-auto" %>
        <% else %>
          <%= link_to "Начать", new_user_registration_path, class: "inline-flex w-full items-center justify-center rounded-2xl bg-green-400 px-6 py-3 font-bold text-black transition hover:bg-green-300 sm:w-auto" %>
          <%= link_to "Уже есть аккаунт", new_user_session_path, class: "inline-flex w-full items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-6 py-3 font-semibold text-white transition hover:bg-white/10 sm:w-auto" %>
        <% end %>
      </div>
      <dl class="mt-9 grid w-full max-w-2xl grid-cols-1 gap-3 text-center min-[420px]:grid-cols-3 sm:mt-10 sm:text-left">
        <div class="min-w-0 rounded-3xl border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
          <dt class="truncate text-sm text-neutral-400">Артисты</dt>
          <dd class="mt-1 text-2xl font-black"><%= number_with_delimiter(@artists_count) %></dd>
        </div>
        <div class="min-w-0 rounded-3xl border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
          <dt class="truncate text-sm text-neutral-400">Альбомы</dt>
          <dd class="mt-1 text-2xl font-black"><%= number_with_delimiter(@albums_count) %></dd>
        </div>
        <div class="min-w-0 rounded-3xl border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
          <dt class="truncate text-sm text-neutral-400">Треки</dt>
          <dd class="mt-1 text-2xl font-black"><%= number_with_delimiter(@tracks_count) %></dd>
        </div>
      </dl>
    </div>

    <div class="relative mx-auto w-full max-w-full min-w-0 sm:max-w-xl">
      <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-green-400/20 via-[#4F4A85]/25 to-transparent blur-2xl sm:-inset-6 sm:rounded-[3rem]"></div>
      <div class="relative max-w-full overflow-hidden rounded-[2rem] border border-white/10 bg-neutral-950/70 p-4 shadow-2xl shadow-black/50 backdrop-blur-xl sm:rounded-[2.5rem] sm:p-6">
        <div class="rounded-[1.5rem] border border-neutral-800 bg-neutral-900/90 p-4 sm:rounded-[2rem] sm:p-5">
          <div class="flex min-w-0 items-center justify-between gap-3">
            <div class="min-w-0 flex-1">
              <p class="text-sm text-neutral-500">Случайный трек из каталога</p>
              <h2 class="mt-1 break-words text-2xl font-black leading-tight"><%= featured_track_title %></h2>
              <p class="mt-1 break-words text-neutral-400"><%= featured_track_artist %></p>
            </div>
            <div class="h-16 w-16 shrink-0 overflow-hidden rounded-2xl bg-neutral-950 shadow-lg shadow-black/30 ring-1 ring-neutral-800 sm:h-20 sm:w-20">
              <%= image_tag featured_track_cover, class: "h-full w-full object-cover", alt: featured_track_title %>
            </div>
          </div>

          <div class="wave-card-bars mt-7 flex h-28 max-w-full items-center justify-between gap-1 overflow-hidden rounded-3xl bg-neutral-950/80 p-4 ring-1 ring-neutral-800 sm:mt-8 sm:h-32 sm:p-5">
            <% [36, 84, 54, 118, 72, 96, 46, 130, 86, 60, 108, 76, 40, 116, 68, 92, 56, 124, 80, 52, 100, 70, 44, 112].each do |height| %>
              <span style="height: <%= height %>px"></span>
            <% end %>
          </div>

        </div>
      </div>
    </div>
  </section>
</main>
