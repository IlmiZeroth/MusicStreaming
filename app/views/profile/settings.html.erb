<%= render "shared/header" %>
<div class = "settings flex justify-center items-center h-screen mt-25 mb-40">
<div class = "settings-card w-1/3 bg-neutral-800 rounded-2xl flex flex-col text-white font-bold">
  <div class = "settings-header pl-2 pt-2 pb-2 flex flex-row gap-5 border border-solid border-neutral-700 rounded-2xl">
    <div class = "return w-8 h-8 text-2xl text-neutral-700">
      <%= link_to :back do %>
        ←
      <% end %>
    </div>
    <div class = "title text-2xl"> Настройки </div>
  </div>
  <%= form_with model: @user, url: profile_update_settings_path, method: :patch, local: true, class: "flex flex-col p-6 gap-5" do |f| %>

    <div class="avatar flex flex-col items-center gap-2">
      <div class="artist-avatar h-28 w-28 rounded-2xl overflow-hidden bg-neutral-700">
        <div data-controller="avatar-preview" class="avatar flex flex-col items-center gap-2">
          <div class="artist-avatar h-28 w-28 rounded-2xl overflow-hidden bg-neutral-700">
            <img data-avatar-preview-target="preview"
                 class="w-full h-full object-cover"
                 src="<%= @user.persisted? && @user.avatar.attached? && @user.avatar.blob&.persisted? ? url_for(@user.avatar) : asset_path('default-user.svg') %>" />
          </div>

          <div class="change-avatar relative">
            <%= f.label :avatar, "Сменить аватар", class: "hover:text-neutral-400 cursor-pointer" %>
            <%= f.file_field :avatar,
                             class: "hidden",
                             accept: "image/png,image/jpeg,image/jpg,image/webp",
                             data: {
                               action: "change->avatar-preview#preview",
                               avatar_preview_target: "input"
                             } %>
          </div>
        </div>
      </div>

      <div class="change-avatar relative">
        <%= f.label :avatar, "Сменить аватар", class: "hover:text-neutral-400 cursor-pointer" %>
        <%= f.file_field :avatar,
                         class: "hidden",
                         accept: "image/png,image/jpeg,image/jpg,image/webp",
                         direct_upload: false,
                         data: {
                           action: "change->avatar-preview#preview",
                           avatar_preview_target: "input"
                         } %>
      </div>
      <p class="text-xs text-neutral-500">Поддерживаемые форматы: PNG, JPG, WEBP</p>
    </div>

    <div class="form-group flex flex-col gap-1">
      <%= f.label :username, "Имя пользователя", class: "text-sm text-neutral-400" %>
      <%= f.text_field :username, class: "bg-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500", placeholder: "Введите имя пользователя" %>
    </div>

    <div class="form-group flex flex-col gap-1">
      <%= f.label :email, "Email", class: "text-sm text-neutral-400" %>
      <%= f.email_field :email, class: "bg-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500", placeholder: "example@mail.com" %>
    </div>

    <div class="border-t border-neutral-700 pt-4 mt-2">
      <h3 class="text-lg font-semibold mb-3">Изменить пароль</h3>

      <div class="form-group flex flex-col gap-1 mb-3">
        <%= f.label :password, "Новый пароль", class: "text-sm text-neutral-400" %>
        <%= f.password_field :password, class: "bg-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500", placeholder: "Оставьте пустым, если не хотите менять" %>
      </div>

      <div class="form-group flex flex-col gap-1">
        <%= f.label :password_confirmation, "Подтверждение пароля", class: "text-sm text-neutral-400" %>
        <%= f.password_field :password_confirmation, class: "bg-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500", placeholder: "Повторите новый пароль" %>
      </div>
    </div>

    <div class="flex gap-3 mt-4">
      <%= f.submit "Сохранить изменения", class: "flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-lg transition cursor-pointer" %>
      <%= link_to "Отмена", profile_settings_path, class: "flex-1 bg-neutral-700 hover:bg-neutral-600 text-white font-bold py-2 px-4 rounded-lg transition text-center" %>
    </div>
  <% end %>

  <div class="p-6 pt-0 border-t border-neutral-700 mt-2">
    <div class="mt-4 pt-2">
      <%= button_to "Удалить аккаунт", user_registration_path, method: :delete,
                    data: { turbo_confirm: "Вы уверены? Это действие необратимо!" },
                    class: "w-full bg-transparent border-2 border-red-600 text-red-600 hover:bg-red-600 hover:text-white font-bold py-2 px-4 rounded-lg transition cursor-pointer" %>
    </div>
  </div>
</div>
</div>