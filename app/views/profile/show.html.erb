<%= render "shared/header" %>

<% popular_queue = player_tracks_payload(@popular_tracks) %>
<% first_popular_track = popular_queue.first %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <button type="button"
            data-controller="smart-back"
            data-action="click->smart-back#goBack"
            data-smart-back-fallback-url-value="<%= pages_path %>"
            class="mb-5 inline-flex items-center gap-2 rounded-2xl bg-neutral-950/70 px-3 py-2 text-sm text-neutral-300 ring-1 ring-neutral-800 transition hover:bg-neutral-800 hover:text-white"
            title="Назад">
      <%= image_tag "left.svg", class: "h-4 w-4" %> Назад
    </button>

    <div class="grid gap-6 md:grid-cols-[12rem_1fr] md:items-end">
      <div class="aspect-square overflow-hidden rounded-[2rem] bg-neutral-800 ring-1 ring-neutral-800">
        <% if @artist.avatar.attached? %>
          <%= image_tag @artist.avatar, class: "h-full w-full object-cover", alt: @artist.name %>
        <% else %>
          <div class="flex h-full w-full items-center justify-center p-10"><%= image_tag "default-user.svg", class: "h-full w-full", alt: @artist.name %></div>
        <% end %>
      </div>

      <div class="min-w-0">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Исполнитель</p>
        <h1 class="mt-2 break-words pb-1 text-4xl font-black leading-[1.12] tracking-tight text-white sm:text-5xl sm:leading-[1.12]" title="<%= @artist.name %>"><%= @artist.name %></h1>
        <% if @artist.description.present? %>
          <p class="mt-3 max-w-3xl leading-7 text-neutral-400"><%= @artist.description %></p>
        <% end %>

        <div class="mt-5 flex flex-wrap gap-2 text-sm text-neutral-300">
          <span class="rounded-full bg-neutral-950/70 px-3 py-1.5 ring-1 ring-neutral-800"><%= number_with_delimiter @artist.total_streams %> прослушиваний</span>
          <span class="rounded-full bg-neutral-950/70 px-3 py-1.5 ring-1 ring-neutral-800"><%= number_with_delimiter @artist.tracks_count %> треков</span>
          <span class="rounded-full bg-neutral-950/70 px-3 py-1.5 ring-1 ring-neutral-800"><%= number_with_delimiter @artist.albums_count %> альбомов</span>
        </div>

        <div class="mt-6 flex flex-wrap items-center gap-3">
          <% if first_popular_track.present? %>
            <button type="button"
                    data-controller="album-card"
                    data-action="click->album-card#playTrack"
                    data-album-card-id-value="<%= first_popular_track[:id] %>"
                    data-album-card-artist-value="<%= first_popular_track[:artist] %>"
                    data-album-card-name-value="<%= first_popular_track[:name] %>"
                    data-album-card-url-value="<%= first_popular_track[:url] %>"
                    data-album-card-metadata-url-value="<%= first_popular_track[:metadataUrl] %>"
                    data-album-card-duration-value="<%= first_popular_track[:duration] %>"
                    data-album-card-image-value="<%= first_popular_track[:image] %>"
                    data-album-card-liked-value="<%= first_popular_track[:liked] %>"
                    data-album-card-like-url-value="<%= first_popular_track[:likeUrl] %>"
                    data-album-card-unlike-url-value="<%= first_popular_track[:unlikeUrl] %>"
                    data-album-card-queue-name-value="Популярные треки — <%= @artist.name %>"
                    data-album-card-queue-value="<%= popular_queue.to_json %>"
                    data-album-card-context-type-value="artist-popular"
                    data-album-card-context-id-value="<%= @artist.id %>"
                    data-album-card-context-url-value="<%= profile_path(@artist) %>"
                    data-album-card-play-icon-value="<%= asset_path('play.svg') %>"
                    data-album-card-pause-icon-value="<%= asset_path('pause.svg') %>"
                    class="inline-flex items-center gap-2 rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300">
              <%= image_tag "play.svg", class: "h-5 w-5", data: { album_card_target: "playIcon" } %> Слушать
            </button>
          <% else %>
            <button type="button" disabled class="inline-flex items-center gap-2 rounded-2xl bg-neutral-800 px-5 py-3 font-bold text-neutral-500 cursor-not-allowed"><%= image_tag "play.svg", class: "h-5 w-5 opacity-50" %> Слушать</button>
          <% end %>

          <% if current_user.following?(@artist) %>
            <%= button_to "Вы подписаны", unfollow_path(@artist), method: :delete, class: "rounded-2xl border border-green-400/60 bg-green-400/10 px-5 py-3 font-semibold text-green-200 transition hover:bg-green-400 hover:text-black cursor-pointer" %>
          <% else %>
            <%= button_to "+ Подписаться", follow_path(@artist), method: :post, class: "rounded-2xl border border-neutral-700 bg-neutral-950/70 px-5 py-3 font-semibold text-white transition hover:border-green-400/70 hover:text-green-200 cursor-pointer" %>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <% if @popular_tracks.blank? && @artist_albums.blank? %>
    <%= render "shared/empty_state",
               title: "У исполнителя пока нет музыки",
               description: "Когда модераторы загрузят треки или альбомы, они появятся на этой странице." %>
  <% else %>
    <% if @popular_tracks.present? %>
      <section class="mt-8" data-controller="horizontal-scroll" data-playback-queue-name-value="Популярные треки — <%= @artist.name %>" data-playback-context-type-value="artist-popular" data-playback-context-id-value="<%= @artist.id %>" data-playback-context-url-value="<%= profile_path(@artist) %>">
        <div class="flex items-end justify-between gap-4">
          <div><p class="text-sm text-neutral-500">Самое слушаемое</p><h2 class="text-2xl font-bold text-white">Популярные треки</h2></div>
          <div class="hidden items-center gap-2 sm:flex"><button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag "left.svg", class: "h-5 w-5" %></button><button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag "right.svg", class: "h-5 w-5" %></button></div>
        </div>
        <div class="mt-4 flex gap-4 overflow-x-auto pb-3" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
          <% @popular_tracks.each do |track| %><%= render "shared/track_card", track: track %><% end %>
        </div>
      </section>
    <% end %>

    <% if @artist_albums.present? %>
      <section class="mt-8" data-controller="horizontal-scroll">
        <div class="flex items-end justify-between gap-4">
          <div><p class="text-sm text-neutral-500">Дискография</p><h2 class="text-2xl font-bold text-white">Альбомы</h2></div>
          <div class="hidden items-center gap-2 sm:flex"><button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag "left.svg", class: "h-5 w-5" %></button><button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag "right.svg", class: "h-5 w-5" %></button></div>
        </div>
        <div class="mt-4 flex gap-4 overflow-x-auto pb-3" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
          <% @artist_albums.each do |album| %><%= render "shared/album_card", album: album %><% end %>
        </div>
      </section>
    <% end %>
  <% end %>
</main>
