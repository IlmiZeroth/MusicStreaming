<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between"><div><p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Релизы</p><h1 class="mt-2 text-3xl font-black text-white sm:text-4xl">Альбомы</h1><p class="mt-2 text-neutral-400">Создавайте альбомы через поиск артиста.</p></div><div class="flex flex-wrap gap-2"><%= link_to "+ Альбом", new_moderation_album_path, class: primary_button_class %><%= link_to "Панель", moderation_root_path, class: secondary_button_class %></div></div>
  </section>

  <section class="mt-6 rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-4 sm:p-6">
<%= render "shared/pagination_filter", label: "Поиск альбомов", placeholder: "Альбом, артист или дата" %>
    <div class="overflow-x-auto"><table class="w-full min-w-[860px] text-left text-sm"><thead class="border-b border-neutral-800 text-neutral-500"><tr><th class="py-3 font-medium">Альбом</th><th class="font-medium">Артист</th><th class="font-medium">Дата</th><th class="font-medium">Треки</th><th class="font-medium">Стримы</th><th></th></tr></thead><tbody class="divide-y divide-neutral-800/80">
      <% @albums.each do |album| %>
        <tr><td class="py-3 font-semibold"><%= link_to album.name, album_path(album), class: "hover:text-green-300" %></td><td><%= link_to album.artist.name, profile_path(album.artist), class: "text-neutral-300 hover:text-white" %></td><td class="text-neutral-400"><%= album.release_date %></td><td><%= album.tracks_count %></td><td><%= album.total_streams %></td><td class="flex justify-end gap-3 py-3"><%= link_to "Загрузить треки", bulk_new_moderation_tracks_path(album_id: album.id), class: "text-green-300 hover:text-green-200" %><%= link_to "Редактировать", edit_moderation_album_path(album), class: "text-neutral-300 hover:text-white" %><%= button_to "Удалить", moderation_album_path(album), method: :delete, data: { turbo_confirm: "Удалить альбом #{album.name}?" }, class: "text-red-300 hover:text-red-200 cursor-pointer" %></td></tr>
      <% end %>
      <% if @albums.empty? %><tr><td colspan="6" class="py-8 text-neutral-400">Альбомов пока нет.</td></tr><% end %>
    </tbody></table></div>
    <%= render "shared/pagination", pagination: @pagination %>
  </section>
</main>
