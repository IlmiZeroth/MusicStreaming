<% if @album.errors.any? %>
  <div class="mb-4 rounded-2xl border border-red-400/60 bg-red-500/10 p-4 text-red-100"><div class="font-bold">Не удалось сохранить альбом:</div><ul class="mt-2 list-disc pl-5"><% @album.errors.full_messages.each do |message| %><li><%= message %></li><% end %></ul></div>
<% end %>

<%= form_with model: [:moderation, @album], local: true, html: { multipart: true, class: "rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7 grid gap-5" } do |f| %>
  <% if @album.persisted? %>
    <div>
      <span class="mb-2 block text-sm text-neutral-400">Артист</span>
      <div class="rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-neutral-200"><%= @album.artist.name %></div>
      <p class="mt-2 text-xs text-neutral-500">Артист у альбома не меняется. Если альбом привязан неверно, проще создать новый альбом у нужного артиста.</p>
    </div>
  <% else %>
    <div class="relative" data-controller="entity-search" data-entity-search-url-value="<%= search_moderation_artists_path %>">
      <%= f.label :artist_id, "Артист *", class: "mb-2 block text-sm text-neutral-400" %>
      <input type="text" value="<%= @selected_artist&.name %>" placeholder="Начните вводить имя артиста" autocomplete="off" required class="w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400" data-entity-search-target="input" data-action="input->entity-search#search focus->entity-search#search">
      <%= f.hidden_field :artist_id, value: @selected_artist&.id, data: { entity_search_target: "hidden" } %>
      <div class="hidden absolute top-full left-0 right-0 z-30 mt-2 overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950 shadow-2xl" data-entity-search-target="results"></div>
    </div>
  <% end %>

  <div class="grid gap-4 sm:grid-cols-2">
    <div><%= f.label :name, "Название альбома *", class: "mb-2 block text-sm text-neutral-400" %><%= f.text_field :name, required: true, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400" %></div>
    <div><%= f.label :release_date, "Дата выпуска *", class: "mb-2 block text-sm text-neutral-400" %><%= f.date_field :release_date, required: true, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400" %></div>
  </div>

  <div><%= f.label :cover_image, "Обложка", class: "mb-2 block text-sm text-neutral-400" %><%= f.file_field :cover_image, accept: "image/png,image/jpeg,image/jpg,image/webp", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white file:mr-4 file:rounded-xl file:border-0 file:bg-neutral-800 file:px-3 file:py-2 file:text-white" %></div>

  <div class="flex flex-col gap-3 sm:flex-row"><%= f.submit @album.persisted? ? "Сохранить" : "Создать альбом", class: "rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300 cursor-pointer" %><%= link_to "Отмена", moderation_albums_path, class: "rounded-2xl border border-neutral-700 bg-neutral-950/70 px-5 py-3 text-center font-semibold text-white transition hover:bg-neutral-800" %></div>
<% end %>
