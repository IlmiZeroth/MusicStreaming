<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between"><div><p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Каталог</p><h1 class="mt-2 text-3xl font-black text-white sm:text-4xl">Артисты</h1></div><div class="flex flex-wrap gap-2"><%= link_to "+ Артист", new_moderation_artist_path, class: primary_button_class %><%= link_to "Панель", moderation_root_path, class: secondary_button_class %></div></div>
  </section>

  <section class="mt-6 rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-4 sm:p-6">
<%= render "shared/pagination_filter", label: "Поиск артистов", placeholder: "Имя артиста или описание" %>
    <div class="overflow-x-auto"><table class="w-full min-w-[820px] text-left text-sm"><thead class="border-b border-neutral-800 text-neutral-500"><tr><th class="py-3 font-medium">Артист</th><th class="font-medium">Описание</th><th class="font-medium">Альбомы</th><th class="font-medium">Треки</th><th></th></tr></thead><tbody class="divide-y divide-neutral-800/80">
      <% @artists.each do |artist| %>
        <tr><td class="py-3 font-semibold"><%= link_to artist.name, profile_path(artist), class: "hover:text-green-300" %></td><td class="max-w-md truncate text-neutral-300"><%= artist.description.presence || "—" %></td><td><%= artist.albums_count %></td><td><%= artist.tracks_count %></td><td class="flex justify-end gap-3 py-3"><%= link_to "Альбом", new_moderation_album_path(artist_id: artist.id), class: "text-green-300 hover:text-green-200" %><%= link_to "Редактировать", edit_moderation_artist_path(artist), class: "text-neutral-300 hover:text-white" %><%= button_to "Удалить", moderation_artist_path(artist), method: :delete, data: { turbo_confirm: "Удалить артиста #{artist.name} вместе с альбомами и треками?" }, class: "text-red-300 hover:text-red-200 cursor-pointer" %></td></tr>
      <% end %>
      <% if @artists.empty? %><tr><td colspan="5" class="py-8 text-neutral-400">Артистов пока нет.</td></tr><% end %>
    </tbody></table></div>
    <%= render "shared/pagination", pagination: @pagination %>
  </section>
</main>
