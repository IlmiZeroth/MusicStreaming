<% if @artist.errors.any? %>
  <div class="mb-4 rounded-2xl border border-red-400/60 bg-red-500/10 p-4 text-red-100">
    <div class="font-bold">Не удалось сохранить артиста:</div>
    <ul class="mt-2 list-disc pl-5"><% @artist.errors.full_messages.each do |message| %><li><%= message %></li><% end %></ul>
  </div>
<% end %>

<%= form_with model: [:moderation, @artist], local: true, html: { multipart: true, class: "rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7 grid gap-5" } do |f| %>
  <div>
    <%= f.label :name, "Имя артиста *", class: "mb-2 block text-sm text-neutral-400" %>
    <%= f.text_field :name, required: true, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400" %>
  </div>

  <div>
    <%= f.label :description, "Описание", class: "mb-2 block text-sm text-neutral-400" %>
    <%= f.text_area :description, rows: 4, class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white outline-none focus:border-green-400" %>
  </div>

  <div>
    <%= f.label :avatar, "Аватар", class: "mb-2 block text-sm text-neutral-400" %>
    <%= f.file_field :avatar, accept: "image/png,image/jpeg,image/jpg,image/webp", class: "w-full rounded-2xl border border-neutral-800 bg-neutral-950/70 px-4 py-3 text-white file:mr-4 file:rounded-xl file:border-0 file:bg-neutral-800 file:px-3 file:py-2 file:text-white" %>
  </div>

  <div class="flex flex-col gap-3 sm:flex-row">
    <%= f.submit @artist.persisted? ? "Сохранить" : "Создать артиста", class: "rounded-2xl bg-green-400 px-5 py-3 font-bold text-black transition hover:bg-green-300 cursor-pointer" %>
    <%= link_to "Отмена", moderation_artists_path, class: "rounded-2xl border border-neutral-700 bg-neutral-950/70 px-5 py-3 text-center font-semibold text-white transition hover:bg-neutral-800" %>
  </div>
<% end %>
