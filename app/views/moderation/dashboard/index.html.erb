<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Модерация</p>
        <h1 class="mt-2 text-3xl font-black text-white sm:text-4xl">Панель модерации</h1>
        <p class="mt-2 text-neutral-400">Здесь модераторы управляют артистами, альбомами и треками.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "Артисты", moderation_artists_path, class: secondary_button_class %>
        <%= link_to "Альбомы", moderation_albums_path, class: secondary_button_class %>
        <%= link_to "Треки", moderation_tracks_path, class: secondary_button_class %>
        <%= link_to "Загрузка треков", bulk_new_moderation_tracks_path, class: secondary_button_class %>
        <% if current_user.admin? %><%= link_to "Админ-панель", admin_root_path, class: primary_button_class %><% end %>
      </div>
    </div>
  </section>

  <section class="mt-6 grid grid-cols-2 gap-3 lg:grid-cols-4">
    <% [["Артисты", @artists_count], ["Альбомы", @albums_count], ["Треки", @tracks_count], ["Ошибки анализа", @failed_tracks_count]].each do |label, value| %>
      <div class="rounded-[1.5rem] border border-neutral-800 bg-neutral-900/70 p-4"><div class="text-sm text-neutral-500"><%= label %></div><div class="mt-2 text-3xl font-black text-white"><%= value %></div></div>
    <% end %>
  </section>

  <section class="mt-6 grid gap-6 xl:grid-cols-2">
    <div class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 sm:p-6">
      <div class="mb-4 flex items-center justify-between"><h2 class="text-2xl font-bold text-white">Новые альбомы</h2><%= link_to "+ Альбом", new_moderation_album_path, class: "text-sm font-semibold text-green-300 hover:text-green-200" %></div>
      <div class="divide-y divide-neutral-800">
        <% @recent_albums.each do |album| %>
          <div class="flex items-center justify-between gap-3 py-3"><div class="min-w-0"><div class="truncate font-semibold"><%= link_to album.name, album_path(album), class: "hover:text-green-300" %></div><div class="truncate text-sm text-neutral-400"><%= album.artist.name %> · <%= album.tracks_count %> треков</div></div><%= link_to "Редактировать", edit_moderation_album_path(album), class: "shrink-0 text-sm text-neutral-300 hover:text-white" %></div>
        <% end %>
      </div>
      <% if @recent_albums.empty? %><p class="text-neutral-400">Альбомов пока нет.</p><% end %>
    </div>

    <div class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 sm:p-6">
      <div class="mb-4 flex items-center justify-between"><h2 class="text-2xl font-bold text-white">Новые треки</h2><span class="flex gap-3"><%= link_to "+ Загрузить", bulk_new_moderation_tracks_path, class: "text-sm font-semibold text-green-300 hover:text-green-200" %></span></div>
      <div class="divide-y divide-neutral-800" data-playback-queue-name-value="Модерация: новые треки" data-playback-context-type-value="moderation_dashboard" data-playback-context-url-value="<%= request.fullpath %>">
        <% @recent_tracks.each do |track| %>
          <% track_audio_url = track.audio_file.attached? ? audio_track_path(track) : "" %>
          <% track_metadata_url = track.audio_file.attached? ? metadata_track_path(track) : "" %>
          <% track_image_url = track.album.cover_image.attached? ? url_for(track.album.cover_image) : asset_path("default-music.svg") %>
          <% liked = current_user.liked_track?(track) %>
          <div data-controller="track-card"
               data-track-card-target="active"
               data-track-card-id-value="<%= track.id %>"
               data-track-card-artist-value="<%= track.artist.name %>"
               data-track-card-name-value="<%= track.name %>"
               data-track-card-url-value="<%= track_audio_url %>"
               data-track-card-metadata-url-value="<%= track_metadata_url %>"
               data-track-card-duration-value="<%= track.duration %>"
               data-track-card-image-value="<%= track_image_url %>"
               data-track-card-liked-value="<%= liked %>"
               data-track-card-like-url-value="<%= like_track_path(track) %>"
               data-track-card-unlike-url-value="<%= unlike_track_path(track) %>"
               data-track-card-play-icon-value="<%= asset_path('play.svg') %>"
               data-track-card-pause-icon-value="<%= asset_path('pause.svg') %>"
               class="flex items-center justify-between gap-3 py-3 transition hover:bg-neutral-900/40">
            <div class="flex min-w-0 items-center gap-3">
              <button type="button" data-action="click->track-card#playTrack" data-track-card-target="artwork" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-neutral-800 transition hover:bg-neutral-700 hover:cursor-pointer disabled:opacity-40 disabled:cursor-default" <%= "disabled" if track_audio_url.blank? %>>
                <%= image_tag "play.svg", class: "h-6 w-6", data: { track_card_target: "playIcon" } %>
              </button>
              <div class="min-w-0"><div class="truncate font-semibold"><%= track.name %></div><div class="truncate text-sm text-neutral-400"><%= track.artist.name %> · <%= track.album.name %> · <%= track.audio_analysis_status %></div></div>
            </div>
            <%= link_to "Редактировать", edit_moderation_track_path(track), class: "shrink-0 text-sm text-neutral-300 hover:text-white" %>
          </div>
        <% end %>
      </div>
      <% if @recent_tracks.empty? %><p class="text-neutral-400">Треков пока нет.</p><% end %>
    </div>
  </section>
</main>
