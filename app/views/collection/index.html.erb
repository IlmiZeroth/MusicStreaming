<%= render "shared/header" %>

<div class="collection-page text-white mb-40">
  <div class="ml-5 mr-5 mt-6 flex flex-col gap-7">
    <div class="flex flex-col gap-2">
      <p class="text-neutral-400">Моя коллекция</p>
      <h1 class="text-4xl font-bold">Всё, что вам понравилось</h1>
    </div>

    <div class="create-playlist rounded-2xl bg-neutral-800 p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-2xl">Создать плейлист</h2>
        <p class="text-neutral-400">Пока плейлист только создаётся и отображается в коллекции. Наполнение треками можно доделать отдельной веткой.</p>
      </div>

      <%= form_with model: @playlist, url: playlists_path, class: "grid grid-cols-3 gap-3" do |form| %>
        <%= form.text_field :name,
                            placeholder: "Название плейлиста",
                            class: "bg-neutral-700 rounded-2xl px-4 py-2 text-white outline-none focus:ring-2" %>
        <%= form.text_field :description,
                            placeholder: "Описание, необязательно",
                            class: "bg-neutral-700 rounded-2xl px-4 py-2 text-white outline-none focus:ring-2" %>
        <%= form.submit "Создать",
                        class: "bg-green-400 text-black rounded-2xl px-4 py-2 hover:cursor-pointer hover:text-gray-700 transition-colors" %>
      <% end %>
    </div>

    <section class="following section" data-controller="horizontal-scroll">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-end gap-3">
          <h2 class="text-2xl">Любимые артисты</h2>
          <span class="text-neutral-400" data-collection-count="artists"><%= @artists.size %></span>
        </div>
        <div class="flex items-center gap-2">
          <button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-800/90 p-1.5 hover:bg-neutral-700 disabled:opacity-30 disabled:cursor-default transition-colors" title="Назад">
            <%= image_tag 'left.svg', class: 'w-5 h-5' %>
          </button>
          <button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-800/90 p-1.5 hover:bg-neutral-700 disabled:opacity-30 disabled:cursor-default transition-colors" title="Вперёд">
            <%= image_tag 'right.svg', class: 'w-5 h-5' %>
          </button>
        </div>
      </div>
      <% if @artists.present? %>
        <div class="flex flex-row gap-5 mt-3 py-1 px-1 overflow-x-auto" data-collection-list="artists" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
          <% @artists.each do |artist| %>
            <%= render 'shared/artist_card', artist: artist, show_actions: true %>
          <% end %>
        </div>
        <p class="mt-3 hidden rounded-2xl bg-neutral-800 p-5 text-neutral-400" data-collection-empty="artists">Здесь появятся артисты, на которых вы подпишетесь.</p>
      <% else %>
        <p class="mt-3 rounded-2xl bg-neutral-800 p-5 text-neutral-400" data-collection-empty="artists">Здесь появятся артисты, на которых вы подпишетесь.</p>
      <% end %>
    </section>

    <section class="liked-tracks section">
      <div class="flex items-end justify-between gap-3">
        <h2 class="text-2xl">Понравившиеся треки</h2>
        <span class="text-neutral-400"><%= @liked_tracks.size %></span>
      </div>
      <% if @liked_tracks.present? %>
        <div class="tracks flex flex-col gap-3 mt-3 py-1 overflow-visible" data-playback-queue-name-value="Понравившиеся треки">
          <% @liked_tracks.each do |track| %>
            <%= render 'shared/track', track: track, show_actions: false, show_like: true %>
          <% end %>
        </div>
      <% else %>
        <p class="mt-3 rounded-2xl bg-neutral-800 p-5 text-neutral-400">Нажимайте на плюс у треков — они появятся здесь.</p>
      <% end %>
    </section>

    <section class="liked-albums section" data-controller="horizontal-scroll">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-end gap-3">
          <h2 class="text-2xl">Любимые альбомы</h2>
          <span class="text-neutral-400"><%= @liked_albums.size %></span>
        </div>
        <div class="flex items-center gap-2">
          <button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-800/90 p-1.5 hover:bg-neutral-700 disabled:opacity-30 disabled:cursor-default transition-colors" title="Назад">
            <%= image_tag 'left.svg', class: 'w-5 h-5' %>
          </button>
          <button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-800/90 p-1.5 hover:bg-neutral-700 disabled:opacity-30 disabled:cursor-default transition-colors" title="Вперёд">
            <%= image_tag 'right.svg', class: 'w-5 h-5' %>
          </button>
        </div>
      </div>
      <% if @liked_albums.present? %>
        <div class="flex flex-row gap-5 mt-3 py-1 px-1 overflow-x-auto" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
          <% @liked_albums.each do |album| %>
            <%= render 'shared/album_card', album: album, show_like: true %>
          <% end %>
        </div>
      <% else %>
        <p class="mt-3 rounded-2xl bg-neutral-800 p-5 text-neutral-400">Любимые альбомы появятся после нажатия на плюс у альбома.</p>
      <% end %>
    </section>

    <section class="created-playlists section" data-controller="horizontal-scroll">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-end gap-3">
          <h2 class="text-2xl">Мои плейлисты</h2>
          <span class="text-neutral-400"><%= @created_playlists.size %></span>
        </div>
        <div class="flex items-center gap-2">
          <button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-800/90 p-1.5 hover:bg-neutral-700 disabled:opacity-30 disabled:cursor-default transition-colors" title="Назад">
            <%= image_tag 'left.svg', class: 'w-5 h-5' %>
          </button>
          <button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-800/90 p-1.5 hover:bg-neutral-700 disabled:opacity-30 disabled:cursor-default transition-colors" title="Вперёд">
            <%= image_tag 'right.svg', class: 'w-5 h-5' %>
          </button>
        </div>
      </div>
      <% if @created_playlists.present? %>
        <div class="flex flex-row gap-5 mt-3 py-1 px-1 overflow-x-auto" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
          <% @created_playlists.each do |playlist| %>
            <%= render 'shared/playlist_card', playlist: playlist, show_like: false %>
          <% end %>
        </div>
      <% else %>
        <p class="mt-3 rounded-2xl bg-neutral-800 p-5 text-neutral-400">Создайте первый плейлист через форму выше.</p>
      <% end %>
    </section>

    <section class="liked-playlists section" data-controller="horizontal-scroll">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-end gap-3">
          <h2 class="text-2xl">Понравившиеся плейлисты</h2>
          <span class="text-neutral-400"><%= @liked_playlists.size %></span>
        </div>
        <div class="flex items-center gap-2">
          <button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-800/90 p-1.5 hover:bg-neutral-700 disabled:opacity-30 disabled:cursor-default transition-colors" title="Назад">
            <%= image_tag 'left.svg', class: 'w-5 h-5' %>
          </button>
          <button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-800/90 p-1.5 hover:bg-neutral-700 disabled:opacity-30 disabled:cursor-default transition-colors" title="Вперёд">
            <%= image_tag 'right.svg', class: 'w-5 h-5' %>
          </button>
        </div>
      </div>
      <% if @liked_playlists.present? %>
        <div class="flex flex-row gap-5 mt-3 py-1 px-1 overflow-x-auto" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
          <% @liked_playlists.each do |playlist| %>
            <%= render 'shared/playlist_card', playlist: playlist, show_like: true %>
          <% end %>
        </div>
      <% else %>
        <p class="mt-3 rounded-2xl bg-neutral-800 p-5 text-neutral-400">Понравившиеся чужие плейлисты будут здесь, когда появится полноценная страница плейлистов.</p>
      <% end %>
    </section>
  </div>
</div>
