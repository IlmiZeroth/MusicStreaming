<%= render "shared/header" %>

<main class="<%= page_shell_class %>">
  <section class="rounded-[2rem] border border-neutral-800 bg-neutral-900/70 p-5 shadow-xl shadow-black/20 sm:p-7">
    <div class="grid gap-6 lg:grid-cols-[1fr_24rem] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-300">Моя коллекция</p>
        <h1 class="mt-2 text-3xl font-black text-white sm:text-4xl">Всё, что вам понравилось</h1>
        <p class="mt-2 max-w-2xl text-neutral-400">Подписки, любимые треки, альбомы и ваши плейлисты собраны в одном пространстве.</p>
      </div>
      <div class="rounded-[1.5rem] border border-neutral-800 bg-neutral-950/60 p-4">
        <h2 class="text-lg font-bold text-white">Создать плейлист</h2>
        <%= form_with model: @playlist, url: playlists_path, class: "mt-3 grid gap-3" do |form| %>
          <%= form.text_field :name, placeholder: "Название", class: "rounded-2xl border border-neutral-800 bg-neutral-900 px-4 py-3 text-sm text-white outline-none focus:border-green-400" %>
          <%= form.text_field :description, placeholder: "Описание, необязательно", class: "rounded-2xl border border-neutral-800 bg-neutral-900 px-4 py-3 text-sm text-white outline-none focus:border-green-400" %>
          <%= form.submit "Создать", class: "rounded-2xl bg-green-400 px-4 py-3 font-bold text-black transition hover:bg-green-300 hover:cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="mt-8" data-controller="horizontal-scroll">
    <div class="flex items-end justify-between gap-4"><div><p class="text-sm text-neutral-500">Подписки</p><h2 class="text-2xl font-bold text-white">Любимые артисты <span class="text-neutral-500"><%= @artists.size %></span></h2></div><div class="hidden items-center gap-2 sm:flex"><button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag 'left.svg', class: 'h-5 w-5' %></button><button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag 'right.svg', class: 'h-5 w-5' %></button></div></div>
    <% if @artists.present? %>
      <div class="mt-4 flex gap-4 overflow-x-auto pb-3" data-collection-list="artists" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
        <% @artists.each do |artist| %><%= render 'shared/artist_card', artist: artist, show_actions: true %><% end %>
      </div>
      <p class="mt-3 hidden rounded-2xl border border-neutral-800 bg-neutral-900 p-5 text-neutral-400" data-collection-empty="artists">Здесь появятся артисты, на которых вы подпишетесь.</p>
    <% else %>
      <%= render "shared/empty_state", title: "Любимых артистов пока нет", description: "Откройте страницу артиста и подпишитесь, чтобы он появился здесь." %>
    <% end %>
  </section>

  <section class="mt-8" data-playback-queue-name-value="Понравившиеся треки">
    <div class="mb-4"><p class="text-sm text-neutral-500">Ваши лайки</p><h2 class="text-2xl font-bold text-white">Понравившиеся треки <span class="text-neutral-500"><%= @liked_tracks.size %></span></h2></div>
    <% if @liked_tracks.present? %>
      <div class="flex flex-col gap-3">
        <% @liked_tracks.each do |track| %><%= render 'shared/track', track: track, show_actions: false, show_like: true %><% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "Понравившихся треков пока нет", description: "Нажимайте на плюс у треков — они появятся здесь." %>
    <% end %>
  </section>

  <section class="mt-8" data-controller="horizontal-scroll">
    <div class="flex items-end justify-between gap-4"><div><p class="text-sm text-neutral-500">Сохранённые релизы</p><h2 class="text-2xl font-bold text-white">Любимые альбомы <span class="text-neutral-500"><%= @liked_albums.size %></span></h2></div><div class="hidden items-center gap-2 sm:flex"><button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag 'left.svg', class: 'h-5 w-5' %></button><button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag 'right.svg', class: 'h-5 w-5' %></button></div></div>
    <% if @liked_albums.present? %>
      <div class="mt-4 flex gap-4 overflow-x-auto pb-3" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
        <% @liked_albums.each do |album| %><%= render 'shared/album_card', album: album %><% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "Любимых альбомов пока нет", description: "Добавляйте альбомы в коллекцию с их страницы или карточки." %>
    <% end %>
  </section>

  <section class="mt-8" data-controller="horizontal-scroll">
    <div class="flex items-end justify-between gap-4"><div><p class="text-sm text-neutral-500">Создано вами</p><h2 class="text-2xl font-bold text-white">Мои плейлисты <span class="text-neutral-500"><%= @created_playlists.size %></span></h2></div><div class="hidden items-center gap-2 sm:flex"><button type="button" data-action="horizontal-scroll#scrollPrevious" data-horizontal-scroll-target="previousButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag 'left.svg', class: 'h-5 w-5' %></button><button type="button" data-action="horizontal-scroll#scrollNext" data-horizontal-scroll-target="nextButton" class="rounded-full bg-neutral-900 p-2 ring-1 ring-neutral-800 hover:bg-neutral-800 disabled:opacity-30"><%= image_tag 'right.svg', class: 'h-5 w-5' %></button></div></div>
    <% if @created_playlists.present? %>
      <div class="mt-4 flex gap-4 overflow-x-auto pb-3" data-horizontal-scroll-target="scroller" data-action="wheel->horizontal-scroll#scrollByWheel scroll->horizontal-scroll#updateButtons">
        <% @created_playlists.each do |playlist| %><%= render 'shared/playlist_card', playlist: playlist, show_like: false %><% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "Плейлистов пока нет", description: "Создайте плейлист выше или сохраните текущую очередь из плеера." %>
    <% end %>
  </section>
</main>
