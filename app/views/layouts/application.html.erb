<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Music Streaming" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Music Streaming">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= favicon_link_tag "site-icon.ico" %>
    <%= favicon_link_tag "site-icon.png", type: "image/png" %>
    <%= tag.link rel: "apple-touch-icon", href: asset_path("site-icon-180.png") %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "scrollbar", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen overflow-x-hidden bg-neutral-950 text-white antialiased" data-controller="navigation-history">
    <!-- Tailwind safelist for helper-generated classes: mx-auto w-full max-w-7xl px-4 pb-40 pt-6 sm:px-6 lg:px-8 inline-flex items-center justify-center rounded-2xl bg-green-400 px-4 py-2 font-semibold text-black transition hover:bg-green-300 hover:text-neutral-800 border border-neutral-700 bg-neutral-900/70 text-white hover:border-neutral-600 hover:bg-neutral-800 -->
    <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(74,222,128,0.07),transparent_32rem),radial-gradient(circle_at_top_right,rgba(79,70,229,0.12),transparent_34rem)]"></div>

    <% auth_page = controller_path.start_with?("devise/") || controller_path.start_with?("users/") %>

    <% if notice || alert %>
      <div class="pointer-events-none fixed right-4 <%= auth_page ? 'top-4' : 'top-24' %> z-50 grid w-[calc(100%-2rem)] max-w-md gap-3 sm:w-full">
        <% if notice %>
          <p data-controller="notification" data-notification-delay-value="3000" class="pointer-events-auto rounded-2xl border border-green-400/60 bg-neutral-900/95 px-4 py-3 text-sm text-white shadow-2xl shadow-black/40 backdrop-blur">
            <%= notice %>
          </p>
        <% end %>

        <% if alert %>
          <p data-controller="notification" data-notification-delay-value="3500" class="pointer-events-auto rounded-2xl border border-red-400/70 bg-neutral-900/95 px-4 py-3 text-sm text-white shadow-2xl shadow-black/40 backdrop-blur">
            <%= alert %>
          </p>
        <% end %>
      </div>
    <% end %>

    <% if auth_page %>
      <main class="flex min-h-screen items-center justify-center px-4 py-10 sm:px-6">
        <div class="w-full max-w-md rounded-[2rem] border border-neutral-800 bg-neutral-900/80 p-6 shadow-2xl shadow-black/40 backdrop-blur sm:p-8">
          <%= yield %>
        </div>
      </main>
    <% else %>
      <%= yield %>
    <% end %>

    <% if render_player? %>
      <%= render "shared/player_spacer" %>
      <%= render "shared/player" %>
    <% end %>
  </body>
</html>
